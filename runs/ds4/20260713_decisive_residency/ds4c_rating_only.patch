+/* patch 0044: additive SPEX mask lane. The core remains K-by-mass in
+ * g_reap_mask_pruned; these are duplicate-free provisional experts on top. */
+static uint32_t ds4_spex_mask_add_cap(void) {
+    return metal_graph_spex_env_u32("DS4_PACE_LIVEMASK_SPEX_ADD", 0, 16);
+}
+
+static uint32_t ds4_spex_mask_cadence(void) {
+    return metal_graph_spex_env_u32(
+        "DS4_PACE_LIVEMASK_SPEX_CADENCE", 1, 64);
+}
+
+static void ds4_spex_mask_reset_state(void) {
+    int had_pin = 0;
+    for (uint32_t il = 0; il < DS4_MAX_LAYER && !had_pin; il++) {
+        for (uint32_t e = 0; e < DS4_MAX_EXPERT; e++) {
+            if (g_reap_spex_pin[il][e]) {
+                had_pin = 1;
+                break;
+            }
+        }
+    }
+    memset(g_reap_spex_pin, 0, sizeof(g_reap_spex_pin));
+    memset(g_reap_spex_support, 0, sizeof(g_reap_spex_support));
+    memset(g_reap_spex_support_samples, 0,
+           sizeof(g_reap_spex_support_samples));
+    memset(g_reap_spex_last_refresh, 0,
+           sizeof(g_reap_spex_last_refresh));
+    memset(g_reap_spex_refreshed, 0,
+           sizeof(g_reap_spex_refreshed));
+    if (had_pin) g_reap_pin_epoch++;
+}
+
+static uint32_t ds4_spex_mask_copy_active(uint32_t il,
+                                          int32_t *out,
+                                          uint32_t out_cap) {
+    if (il >= DS4_MAX_LAYER || !out || out_cap == 0) return 0;
+    uint32_t n = 0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT && n < out_cap; e++) {
+        if (g_reap_spex_pin[il][e]) out[n++] = (int32_t)e;
+    }
+    return n;
+}
+
+static int ds4_spex_mask_wrap_enabled(void) {
+    static int cached = -1;
+    if (cached < 0) {
+        const char *v = getenv("DS4_PACE_LIVEMASK_SPEX_WRAP");
+        cached = v && v[0] && strcmp(v, "0") != 0;
+    }
+    return cached;
+}
+
+static FILE *ds4_spex_mask_log(void) {
+    static FILE *fh;
+    static int checked;
+    if (!checked) {
+        checked = 1;
+        const char *path = getenv("DS4_PACE_LIVEMASK_SPEX_LOG");
+        if (path && path[0]) fh = fopen(path, "w");
+    }
+    return fh;
+}
+
+static uint32_t ds4_spex_mask_update_layer(
+        const ds4_model   *model,
+        const ds4_weights *weights,
+        uint32_t           pos,
+        uint32_t           source_il,
+        uint32_t           target_il,
+        const int32_t     *ranked_ids,
+        uint32_t           ranked_n,
+        int32_t           *out_add,
+        uint32_t           out_cap) {
+    const uint32_t cap = ds4_spex_mask_add_cap();
+    if (cap == 0 || !ds4_spex_mask_core_ready() ||
+        target_il >= DS4_N_LAYER || target_il >= DS4_MAX_LAYER) {
+        return 0;
+    }
+    double *support = g_reap_spex_support[target_il];
+    for (uint32_t i = 0; ranked_ids && i < ranked_n; i++) {
+        const int32_t id = ranked_ids[i];
+        if (id < 0 || (uint32_t)id >= DS4_N_EXPERT) continue;
+        /* Borda-style rank support in (0,1]. It lets this cadence experiment
+         * aggregate prediction persistence without pretending SPX1 logits are
+         * calibrated gate probabilities. */
+        support[(uint32_t)id] +=
+            (double)(ranked_n - i) / (double)ranked_n;
+    }
+    if (ranked_n > 0) g_reap_spex_support_samples[target_il]++;
+
+    const uint32_t cadence = ds4_spex_mask_cadence();
+    const int refresh = !g_reap_spex_refreshed[target_il] ||
+        pos - g_reap_spex_last_refresh[target_il] >= cadence;
+    if (!refresh) {
+        return ds4_spex_mask_copy_active(target_il, out_add, out_cap);
+    }
+
+    uint8_t next[DS4_MAX_EXPERT];
+    memset(next, 0, sizeof(next));
+    uint32_t n = 0;
+    while (n < cap && n < out_cap) {
+        int32_t best = -1;
+        double best_support = 0.0;
+        for (uint32_t e = 0; e < DS4_N_EXPERT; e++) {
+            if (!g_reap_mask_pruned[target_il][e] || next[e]) continue;
+            if (support[e] > best_support ||
+                (support[e] == best_support && support[e] > 0.0 &&
+                 (best < 0 || e < (uint32_t)best))) {
+                best = (int32_t)e;
+                best_support = support[e];
+            }
+        }
+        if (best < 0 || best_support <= 0.0) break;
+        next[(uint32_t)best] = 1;
+        n++;
+    }
+
+    uint8_t *cur = g_reap_spex_pin[target_il];
+    /* No usable prediction means hold the current lane; never turn a transient
+     * readback miss into an eviction of all provisional experts. */
+    if (n == 0) memcpy(next, cur, DS4_N_EXPERT);
+
+    ds4_reap_expert_id batch[16];
+    uint32_t entrants = 0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT && entrants < 16; e++) {
+        if (next[e] && !cur[e]) {
+            batch[entrants].layer = target_il;
+            batch[entrants].expert = e;
+            entrants++;
+        }
+    }
+
+    int wrap_ready = 1;
+    double wrap_ms = 0.0;
+    if (entrants > 0 && ds4_spex_mask_wrap_enabled()) {
+        const double wrap_t0 = now_sec();
+        wrap_ready = ds4_reap_prefetch_batch_sync(
+            model, weights, batch, entrants);
+        wrap_ms = (now_sec() - wrap_t0) * 1000.0;
+    }
+
+    int changed = 0;
+    if (wrap_ready) {
+        changed = memcmp(cur, next, DS4_N_EXPERT) != 0;
+        if (changed) {
+            memcpy(cur, next, DS4_N_EXPERT);
+            g_reap_pin_epoch++;
+            (void)ds4_reap_mask_apply_layer(model, weights, target_il);
+        }
+        g_reap_spex_last_refresh[target_il] = pos;
+        g_reap_spex_refreshed[target_il] = 1;
+        memset(support, 0, DS4_MAX_EXPERT * sizeof(*support));
+        g_reap_spex_support_samples[target_il] = 0;
+    }
+    n = ds4_spex_mask_copy_active(target_il, out_add, out_cap);
+
+    FILE *fh = ds4_spex_mask_log();
+    if (fh) {
+        fprintf(fh,
+                "{\"ev\":\"spex_add\",\"pos\":%u,\"source_layer\":%u,"
+                "\"target_layer\":%u,\"ranked\":%u,\"active\":%u,"
+                "\"entrants\":%u,\"cadence\":%u,\"changed\":%d,"
+                "\"wrap_ready\":%d,\"wrap_ms\":%.3f,"
+                "\"ids\":[",
+                pos, source_il, target_il, ranked_n, n, entrants, cadence, changed,
+                wrap_ready, wrap_ms);
+        for (uint32_t i = 0; i < n; i++)
+            fprintf(fh, "%s%d", i ? "," : "", out_add[i]);
+        fprintf(fh, "]}\n");
+        fflush(fh);
+    }
+    return n;
+}
+
+/* End the one-layer lease after the target router has selected and its expert
+ * load has been submitted. The slot stays physically pinned until the next
+ * cache reconciliation, so an in-flight upload/compute cannot lose residency. */
+static void ds4_spex_mask_consume_layer(const ds4_model   *model,
+                                        const ds4_layer_weights *layer,
+                                        uint32_t           pos,
+                                        uint32_t           il) {
+    if (ds4_spex_mask_add_cap() == 0 || il >= DS4_MAX_LAYER) return;
+    /* Cadence > 1 is a multi-token lease. The lane is replaced atomically by
+     * the next admission epoch instead of being discarded after one use. */
+    if (ds4_spex_mask_cadence() > 1) return;
+    uint8_t *row = g_reap_spex_pin[il];
+    uint32_t released = 0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT; e++) released += row[e] != 0;
+    if (released == 0) return;
+    memset(row, 0, DS4_N_EXPERT);
+    g_reap_pin_epoch++;
+    (void)ds4_reap_mask_apply_layer_direct(model, layer, il);
+    FILE *fh = ds4_spex_mask_log();
+    if (fh) {
+        fprintf(fh,
+                "{\"ev\":\"spex_consume\",\"pos\":%u,\"layer\":%u,"
+                "\"released\":%u}\n",
+                pos, il, released);
+        fflush(fh);
+    }
+}
