+/* Fire the delta page-in async.  Copies the id list into thread-owned args so
+ * the caller's buffer (and any later mask mutation) cannot race the worker.
+ * Bounds one delta in flight via g_reap_prefetch_delta_busy; a skipped batch is
+ * harmless because the next swap batch re-warms.  Fire-and-forget (detached);
+ * no join on the decode path => cannot stall decode. */
+static void ds4_reap_prefetch_batch(const ds4_model          *model,
+                                    const ds4_weights        *weights,
+                                    const ds4_reap_expert_id *ids,
+                                    uint32_t                  n) {
+    if (!ds4_reap_prefetch_delta_enabled()) return;
+    if (!model || !weights || !ids || n == 0) return;
+    if (__sync_lock_test_and_set(&g_reap_prefetch_delta_busy, 1)) {
+        return;                 /* a delta is already in flight */
+    }
+    ds4_reap_prefetch_batch_args *args = xmalloc(sizeof(*args));
+    args->model   = model;
+    args->weights = weights;
+    args->ids     = xmalloc((size_t)n * sizeof(*args->ids));
+    memcpy(args->ids, ids, (size_t)n * sizeof(*args->ids));
+    args->n       = n;
+    args->log     = 1;
+    pthread_t th;
+    if (pthread_create(&th, NULL, ds4_reap_prefetch_batch_main, args) != 0) {
+        free(args->ids);
+        free(args);
+        g_reap_prefetch_delta_busy = 0;
+        fprintf(stderr, "ds4: REAP prefetch delta: pthread_create fallita\n");
+        return;
+    }
+    pthread_detach(th);
+}
