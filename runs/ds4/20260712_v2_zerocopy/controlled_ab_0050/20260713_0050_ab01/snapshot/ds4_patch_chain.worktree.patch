+static int ds4_reap_prefetch_batch_sync(const ds4_model          *model,
+                                        const ds4_weights        *weights,
+                                        const ds4_reap_expert_id *ids,
+                                        uint32_t                  n) {
+    if (!ds4_reap_prefetch_delta_enabled() || !model || !weights || !ids || n == 0)
+        return 0;
+    if (__sync_lock_test_and_set(&g_reap_prefetch_delta_busy, 1)) return 0;
+    ds4_reap_prefetch_batch_args *args = xmalloc(sizeof(*args));
+    args->model   = model;
+    args->weights = weights;
+    args->ids     = xmalloc((size_t)n * sizeof(*args->ids));
+    memcpy(args->ids, ids, (size_t)n * sizeof(*args->ids));
+    args->n       = n;
+    args->log     = 0;
+    (void)ds4_reap_prefetch_batch_main(args);
+    return 1;
+}
