+#if !defined(DS4_ROCM_BUILD) && !defined(DS4_NO_GPU) && !defined(__APPLE__)
+/* ---- patch 0050: zero-copy masked-window streaming (DS4_CUDA_STREAM_FROM_RAM_MASKED)
+ * Eliminates the per-access pread+stage+H2D+sync toll for the RAM-resident REAP
+ * keep-window: instead of the CUDA path re-fetching each selected expert's
+ * bytes from the fd every decode step (chapters 0011/0013 above only warm the
+ * page cache -- ds4_gpu_stream_expert_cache_seed_experts* still does a real
+ * pread through that warm cache on every call), pre-register the whole
+ * keep-window as GPU-mapped pinned host memory ONCE at load time via
+ * cuda_model_range_register_mapped (chripell's approach, upstream
+ * DS4_CUDA_STREAM_FROM_RAM, adapted here to a bounded mask-defined window
+ * instead of the full ~81-96 GiB model -- see AGENT.md 0047: registering the
+ * whole model has an incident history under memory pressure and does not fit
+ * this box's WSL RAM budget anyway). After registration, ordinary
+ * cuda_model_range_ptr() lookups for any kept expert's gate/up/down bytes hit
+ * the registered-range branch directly and never touch the pread path.
+ *
+ * Independent of DS4_REAP_MASK_FILE/g_reap_mask_pruned by design (own env, own
+ * mask array, own file load): this is a static host-RAM residency decision
+ * made once at model load, not a live per-token routing mask, and the two are
+ * allowed to diverge (e.g. testing a registration window narrower than the
+ * live REAP mask). Mask file format is identical to DS4_REAP_MASK_FILE:
+ * one "<layer> <expert>" line per BLOCKED (not kept) expert; the keep set is
+ * the complement. Default (env unset): zero behavioral change, this whole
+ * path is inert. */
+static uint8_t g_stream_masked_pruned[DS4_MAX_LAYER][DS4_MAX_EXPERT];
+static int     g_stream_masked_checked;
+static int     g_stream_masked_loaded;
+
+/* Discovered empirically on the WSL2/RTX3060 dev box (2026-07-12 staged
+ * register test, patch 0050): cudaHostRegister range mapping degrades
+ * gracefully up to roughly 30-31 GiB total pinned, but registering all the
+ * way up to that wall leaves no headroom for the engine's OTHER pinned-host
+ * allocations made later in session setup (selected-stage ring buffers,
+ * ds4_gpu_async_read_alloc, ...): those then fail with a hard
+ * "failed to create cuda session" instead of degrading. Default budget stays
+ * a conservative margin under the observed wall; override for experimentation
+ * once a given box's true ceiling and other-allocation headroom are known. */
+#define DS4_STREAM_FROM_RAM_MASKED_DEFAULT_BUDGET_GB 24
+
+static uint64_t ds4_stream_from_ram_masked_budget_bytes(void) {
+    uint64_t gb = DS4_STREAM_FROM_RAM_MASKED_DEFAULT_BUDGET_GB;
+    const char *env = getenv("DS4_CUDA_STREAM_FROM_RAM_MASKED_BUDGET_GB");
+    if (env && *env) {
+        char *end = NULL;
+        unsigned long v = strtoul(env, &end, 10);
+        if (end != env && v > 0) gb = v;
+    }
+    return gb * 1073741824ull;
+}
+
+static void ds4_stream_from_ram_masked_load(void) {
+    if (g_stream_masked_checked) return;
+    g_stream_masked_checked = 1;
+    const char *p = getenv("DS4_CUDA_STREAM_FROM_RAM_MASKED");
+    if (!p || !*p) return;
+    FILE *f = fopen(p, "r");
+    if (!f) {
+        fprintf(stderr,
+                "ds4: DS4_CUDA_STREAM_FROM_RAM_MASKED: cannot open %s, "
+                "zero-copy masked window disabled\n", p);
+        return;
+    }
+    unsigned l, e, count = 0;
+    while (fscanf(f, "%u %u", &l, &e) == 2) {
+        if (l < DS4_MAX_LAYER && e < DS4_MAX_EXPERT) {
+            g_stream_masked_pruned[l][e] = 1;
+            count++;
+        }
+    }
+    fclose(f);
+    g_stream_masked_loaded = 1;
+    fprintf(stderr,
+            "ds4: CUDA stream-from-RAM masked window: mask %s (%u blocked entries)\n",
+            p, count);
+}
+
+/* Build coalesced (offset,size) ranges for the KEPT experts of every masked
+ * MoE layer (same contiguous-run coalescing as ds4_reap_prefetch_main above,
+ * duplicated rather than shared because that helper is prefetch/threading
+ * specific and this one feeds cudaHostRegister ranges instead of madvise
+ * touches) and register them as zero-copy GPU-mapped host RAM. Runs once at
+ * engine startup, after the model map/fd and weights are established. */
+static void ds4_stream_from_ram_masked_register(const ds4_model *model,
+                                                 const ds4_weights *weights) {
+    ds4_stream_from_ram_masked_load();
+    if (!g_stream_masked_loaded || !model || !weights) return;
+
+    uint32_t cap = 256, n = 0;
+    uint64_t *offs = xmalloc(cap * sizeof(*offs));
+    uint64_t *sizes = xmalloc(cap * sizeof(*sizes));
+    uint32_t n_layers = 0, n_experts_kept = 0;
+    const uint64_t budget_bytes = ds4_stream_from_ram_masked_budget_bytes();
+    uint64_t budgeted_bytes = 0;
+    uint32_t n_runs_skipped_budget = 0;
+
+    /* Pass 1: count masked MoE layers only, to size a PER-LAYER budget share.
+     * Decode walks every layer on the critical path every token, so spending
+     * the whole budget on the first N layers (in scan order) and leaving the
+     * rest at zero coverage barely helps decode even though it looks great
+     * in aggregate GiB registered -- measured on the 2026-07-12 dev box: a
+     * layer-order-first allocation cut prefill time ~3x but decode t/s only
+     * ~1.1x, because every token still pays full toll in the uncovered tail
+     * layers. Splitting the budget evenly across layers instead means every
+     * layer gets *some* zero-copy coverage, so every token's critical path is
+     * shortened, not just the layers that happened to be scanned first. */
+    uint32_t n_masked_layers = 0;
+    for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER; il++) {
+        const ds4_layer_weights *layer = &weights->layer[il];
+        if (!layer->ffn_gate_exps || !layer->ffn_up_exps || !layer->ffn_down_exps) continue;
+        for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+            if (g_stream_masked_pruned[il][e]) { n_masked_layers++; break; }
+        }
+    }
+    const uint64_t per_layer_budget =
+        n_masked_layers > 0 ? budget_bytes / n_masked_layers : 0;
+
+    for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER; il++) {
+        const ds4_layer_weights *layer = &weights->layer[il];
+        if (!layer->ffn_gate_exps || !layer->ffn_up_exps || !layer->ffn_down_exps) {
+            continue;
+        }
+        uint32_t blocked = 0;
+        for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+            blocked += g_stream_masked_pruned[il][e] ? 1u : 0u;
+        }
+        if (blocked == 0) continue;  /* layer absent from mask file: nothing to register */
+        const uint64_t gate_eb = layer->ffn_gate_exps->dim[1] *
+            routed_expert_row_bytes(layer->ffn_gate_exps);
+        const uint64_t up_eb = layer->ffn_up_exps->dim[1] *
+            routed_expert_row_bytes(layer->ffn_up_exps);
+        const uint64_t down_eb = layer->ffn_down_exps->dim[1] *
+            routed_expert_row_bytes(layer->ffn_down_exps);
+        if (gate_eb == 0 || up_eb == 0 || down_eb == 0) continue;
+        n_layers++;
+        uint64_t layer_budgeted_bytes = 0;
+        uint32_t e = 0;
+        while (e < DS4_N_EXPERT && e < DS4_MAX_EXPERT) {
+            if (g_stream_masked_pruned[il][e]) { e++; continue; }
+            const uint32_t first = e;
+            while (e < DS4_N_EXPERT && e < DS4_MAX_EXPERT &&
+                   !g_stream_masked_pruned[il][e]) {
+                e++;
+            }
+            const uint64_t cnt = (uint64_t)(e - first);
+            const uint64_t run_bytes = cnt * (gate_eb + up_eb + down_eb);
+            /* A run is admitted whole or not at all (never split across the
+             * tensor triplet). Gated on BOTH the remaining per-layer share
+             * and the remaining global budget; skipping a run that doesn't
+             * fit does not stop the scan -- a smaller later run in the same
+             * layer, or the next layer entirely, may still fit. */
+            if (layer_budgeted_bytes + run_bytes > per_layer_budget ||
+                budgeted_bytes + run_bytes > budget_bytes) {
+                n_runs_skipped_budget++;
+                continue;  /* e already advanced past this run by the inner while */
+            }
+            n_experts_kept += (uint32_t)cnt;
+            layer_budgeted_bytes += run_bytes;
+            budgeted_bytes += run_bytes;
+            if (n + 3u > cap) {
+                cap *= 2u;
+                offs = xrealloc(offs, cap * sizeof(*offs));
+                sizes = xrealloc(sizes, cap * sizeof(*sizes));
+            }
+            offs[n] = layer->ffn_gate_exps->abs_offset + (uint64_t)first * gate_eb;
+            sizes[n] = cnt * gate_eb;
+            n++;
+            offs[n] = layer->ffn_up_exps->abs_offset + (uint64_t)first * up_eb;
+            sizes[n] = cnt * up_eb;
+            n++;
+            offs[n] = layer->ffn_down_exps->abs_offset + (uint64_t)first * down_eb;
+            sizes[n] = cnt * down_eb;
+            n++;
+        }
+    }
+
+    if (n_runs_skipped_budget > 0) {
+        fprintf(stderr,
+                "ds4: CUDA stream-from-RAM masked window: budget %.2f GiB total / "
+                "%.2f GiB per layer (%u masked layers, "
+                "DS4_CUDA_STREAM_FROM_RAM_MASKED_BUDGET_GB) reached for %u expert "
+                "run%s, left on the normal pread path\n",
+                (double)budget_bytes / 1073741824.0,
+                (double)per_layer_budget / 1073741824.0,
+                n_masked_layers,
+                n_runs_skipped_budget, n_runs_skipped_budget == 1 ? "" : "s");
+    }
+
+    if (n > 0) {
+        uint64_t reg_bytes = 0;
+        int reg_n = ds4_gpu_register_masked_ranges(model->map, model->size,
+                                                    offs, sizes, n, &reg_bytes);
+        fprintf(stderr,
+                "ds4: CUDA stream-from-RAM masked window: %u layer, %u expert kept, "
+                "%u/%u range%s registered, %.2f GiB zero-copy\n",
+                n_layers, n_experts_kept, reg_n, n, n == 1 ? "" : "s",
+                (double)reg_bytes / 1073741824.0);
+    } else {
+        fprintf(stderr,
+                "ds4: CUDA stream-from-RAM masked window: mask loaded but no "
+                "MoE layer matched (empty or non-overlapping mask?)\n");
+    }
+    free(offs);
+    free(sizes);
+}
+#endif /* !DS4_ROCM_BUILD && !DS4_NO_GPU && !__APPLE__ */
+
+/* ---- FATTORINO delta (item 3): async RAM page-in of the newly-promoted
+ * experts on a ds4_pace_livemask_scan batch swap.  Same threaded mmap-touch
+ * machinery as ds4_reap_prefetch_main, but driven by an explicit (layer,expert)
+ * DELTA list instead of scanning the whole mask, so the cold SSD misses the
+ * promoted candidate would otherwise take on its first decode load are hidden.
+ * Pure page-cache warm => output byte-identical; perf only.  This item does NOT
+ * touch the frozen §7 seam (g_reap_pin_mass/g_reap_pin_epoch/DS4_REAP_PIN_BY_MASS
+ * -- those are the ds4_cuda.cu consumer).  Env: DS4_REAP_PREFETCH_DELTA=1 enable
+ * (default 0 => current 0037/0038 path, nothing fires); DS4_REAP_PREFETCH_THREADS
+ * reused for the worker count.  Separate flag from the working-set WRAP gate. */
+typedef struct { uint32_t layer; uint32_t expert; } ds4_reap_expert_id;
+
+static volatile int g_reap_prefetch_delta_busy;
+
+static bool ds4_reap_prefetch_delta_enabled(void) {
+    static int checked, enabled;
+    if (!checked) {
+        checked = 1;
+        const char *p = getenv("DS4_REAP_PREFETCH_DELTA");
+        enabled = (p && *p && strcmp(p, "0") != 0) ? 1 : 0;
+    }
+    return enabled != 0;
+}
+
+typedef struct {
+    const ds4_model    *model;
+    const ds4_weights  *weights;
+    ds4_reap_expert_id *ids;   /* owned; freed by the worker thread */
+    uint32_t            n;
+    int                 log;
+} ds4_reap_prefetch_batch_args;
+
+static void *ds4_reap_prefetch_batch_main(void *argp) {
+    ds4_reap_prefetch_batch_args args = *(ds4_reap_prefetch_batch_args *)argp;
+    free(argp);
+    const ds4_model    *model   = args.model;
+    const ds4_weights  *weights = args.weights;
+    ds4_reap_expert_id *ids     = args.ids;
+    const uint32_t      nid     = args.n;
+    const int           log_it  = args.log;
+    const double t0 = now_sec();
+
+    uint32_t cap = nid * 3u + 3u, n = 0;
+    metal_graph_stream_pagein_range *ranges = xmalloc(cap * sizeof(*ranges));
+    for (uint32_t i = 0; i < nid; i++) {
+        const uint32_t il = ids[i].layer;
+        const uint32_t e  = ids[i].expert;
+        if (il >= DS4_N_LAYER || il >= DS4_MAX_LAYER) continue;
+        if (e  >= DS4_N_EXPERT || e  >= DS4_MAX_EXPERT) continue;
+        const ds4_layer_weights *layer = &weights->layer[il];
+        if (!layer->ffn_gate_exps || !layer->ffn_up_exps ||
+            !layer->ffn_down_exps) {
+            continue;
+        }
+        const uint64_t gate_eb = layer->ffn_gate_exps->dim[1] *
+            routed_expert_row_bytes(layer->ffn_gate_exps);
+        const uint64_t up_eb = layer->ffn_up_exps->dim[1] *
+            routed_expert_row_bytes(layer->ffn_up_exps);
+        const uint64_t down_eb = layer->ffn_down_exps->dim[1] *
+            routed_expert_row_bytes(layer->ffn_down_exps);
+        if (gate_eb == 0 || up_eb == 0 || down_eb == 0) continue;
+        if (n + 3u > cap) {
+            cap *= 2u;
+            ranges = xrealloc(ranges, cap * sizeof(*ranges));
+        }
+        ranges[n].off  = layer->ffn_gate_exps->abs_offset + (uint64_t)e * gate_eb;
+        ranges[n].size = gate_eb; n++;
+        ranges[n].off  = layer->ffn_up_exps->abs_offset   + (uint64_t)e * up_eb;
+        ranges[n].size = up_eb;   n++;
+        ranges[n].off  = layer->ffn_down_exps->abs_offset + (uint64_t)e * down_eb;
+        ranges[n].size = down_eb; n++;
+    }
+    free(ids);
+    if (n == 0) {
+        free(ranges);
