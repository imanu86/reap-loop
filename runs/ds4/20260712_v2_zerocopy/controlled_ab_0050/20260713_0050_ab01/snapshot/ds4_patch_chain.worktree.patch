+/* End the one-layer lease after the target router has selected and its expert
+ * load has been submitted. The slot stays physically pinned until the next
+ * cache reconciliation, so an in-flight upload/compute cannot lose residency. */
+static void ds4_spex_mask_consume_layer(const ds4_model   *model,
+                                        const ds4_layer_weights *layer,
+                                        uint32_t           pos,
+                                        uint32_t           il) {
+    if (ds4_spex_mask_add_cap() == 0 || il >= DS4_MAX_LAYER) return;
+    /* Cadence > 1 is a multi-token lease. The lane is replaced atomically by
+     * the next admission epoch instead of being discarded after one use. */
+    if (ds4_spex_mask_cadence() > 1) return;
+    uint8_t *row = g_reap_spex_pin[il];
+    uint32_t released = 0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT; e++) released += row[e] != 0;
+    if (released == 0) return;
+    memset(row, 0, DS4_N_EXPERT);
+    g_reap_pin_epoch++;
+    (void)ds4_reap_mask_apply_layer_direct(model, layer, il);
+    FILE *fh = ds4_spex_mask_log();
+    if (fh) {
+        fprintf(fh,
+                "{\"ev\":\"spex_consume\",\"pos\":%u,\"layer\":%u,"
+                "\"released\":%u}\n",
+                pos, il, released);
+        fflush(fh);
+    }
+}
