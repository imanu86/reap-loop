+/* PACE state (ds4_pace_phase + g_pace) is defined up with the g_reap_* globals
+ * so patch-0013 ds4_reap_prefetch_working_set can honor g_pace.wrap_on. */
 
 static int pace_env_i(const char *name, int dflt) {
     const char *v = getenv(name);
