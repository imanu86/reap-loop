+static uint32_t metal_graph_spex_hidden_gpu_topk_read(
+        ds4_gpu_graph *g,
+        uint32_t       il,
+        int32_t       *out_ids,
+        uint32_t       out_cap) {
+#if !defined(DS4_ROCM_BUILD) && !defined(DS4_NO_GPU) && !defined(__APPLE__)
+    if (!g || !out_ids || out_cap == 0 ||
+        !g->spex_hidden_topk ||
+        !g->spex_hidden_topk_readback ||
+        !g->spex_hidden_gpu_topk_valid ||
+        g->spex_hidden_gpu_topk_layer != il ||
+        g->spex_hidden_gpu_topk_count == 0) {
+        return 0;
+    }
+    uint32_t n = g->spex_hidden_gpu_topk_count;
+    if (n > out_cap) n = out_cap;
+    if (n > DS4_MAX_EXPERT) n = DS4_MAX_EXPERT;
+    if (!ds4_gpu_async_read_ready(g->spex_hidden_topk_readback)) {
+        return 0;
+    }
+    const uint32_t *tmp =
+        (const uint32_t *)ds4_gpu_async_read_host(g->spex_hidden_topk_readback);
+    if (!tmp) return 0;
+    uint32_t out_n = 0;
+    for (uint32_t i = 0; i < n; i++) {
+        if (tmp[i] >= DS4_N_EXPERT) continue;
+        bool seen = false;
+        for (uint32_t j = 0; j < out_n; j++) {
+            if ((uint32_t)out_ids[j] == tmp[i]) {
+                seen = true;
+                break;
+            }
+        }
+        if (!seen) out_ids[out_n++] = (int32_t)tmp[i];
+    }
+    g->spex_hidden_gpu_topk_valid = false;
+    return out_n;
+#else
+    (void)g;
+    (void)il;
+    (void)out_ids;
+    (void)out_cap;
+    return 0;
+#endif
+}
