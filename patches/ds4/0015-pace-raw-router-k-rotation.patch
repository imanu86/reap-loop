+static int ds4_pace_rotate_maybe(const ds4_model *model, const ds4_weights *weights) {
+    if (!g_pace.rotate_on || !g_pace.rmass || g_pace.phase != PACE_HOLD ||
+        g_pace.cur_keep <= 0 || g_pace.rmass_rows == 0) {
+        return 0;
+    }
+    const uint32_t last_change = g_pace.last_rotate_tok > g_pace.stable_since
+        ? g_pace.last_rotate_tok : g_pace.stable_since;
+    if (g_pace.tok - last_change < g_pace.rotate_every) return 0;
+    ds4_pace_apply_keep_acc(model, weights, g_pace.rmass, g_pace.cur_keep, "rotate");
+    g_pace.last_rotate_tok = g_pace.tok;
+    g_pace.rotate_events++;
+    ds4_pace_emit("rotate", g_pace.ema_ngram, g_pace.ema_hit);
+    return 1;
+}
