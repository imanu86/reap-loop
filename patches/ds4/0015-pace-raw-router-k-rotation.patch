+static inline int ds4_pace_rotate_wants_router(void) {
+    if (!ds4_pace_active()) return 0;
+    return g_pace.rotate_on && g_pace.rmass && !g_pace.in_prefill &&
+           g_pace.phase == PACE_HOLD && g_pace.cur_keep > 0;
+}
+
+static void ds4_pace_note_router_probs(uint32_t il, const float *probs) {
+    if (!probs || il >= DS4_MAX_LAYER || !ds4_pace_rotate_wants_router()) return;
+    double *row = &g_pace.rmass[(size_t)il * DS4_MAX_EXPERT];
+    const double decay = g_pace.rotate_decay;
+    double any = 0.0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+        const double v = (double)probs[e];
+        row[e] = row[e] * decay + v;
+        any += v;
+    }
+    if (any > 0.0) g_pace.rmass_rows++;
+}
