+/* Update only one routed layer after its SPEX provisional lane changes. This
+ * avoids rebuilding all mask ranges up to forty times per decode token. */
+static int ds4_reap_mask_apply_layer(const ds4_model *model,
+                                     const ds4_weights *weights,
+                                     uint32_t target_il) {
+    if (!model || !weights || target_il >= DS4_N_LAYER) return 0;
+    uint32_t slot = 0;
+    for (uint32_t il = 0; il < DS4_N_LAYER && slot < DS4_MAX_LAYER; il++) {
+        const ds4_layer_weights *layer = &weights->layer[il];
+        if (!layer->ffn_exp_probs_b) continue;
+        if (il != target_il) {
+            slot++;
+            continue;
+        }
+        const float *orig =
+            (const float *)tensor_data(model, layer->ffn_exp_probs_b);
+        for (uint32_t e = 0; e < DS4_N_EXPERT; e++) {
+            g_reap_bias_masked[slot][e] = orig[e] +
+                (ds4_reap_mask_effectively_pruned(il, e) ? -1.0e9f : 0.0f);
+        }
+        g_reap_bias_tensor[slot] = layer->ffn_exp_probs_b;
+        if (slot >= g_reap_bias_n) g_reap_bias_n = slot + 1u;
+        return ds4_gpu_model_range_update(
+                   model->map,
+                   layer->ffn_exp_probs_b->abs_offset,
+                   g_reap_bias_masked[slot],
+                   (uint64_t)DS4_N_EXPERT * sizeof(float)) > 0;
+    }
+    return 0;
+}
+
+static int ds4_reap_mask_apply_layer_direct(
+        const ds4_model         *model,
+        const ds4_layer_weights *layer,
+        uint32_t                 il) {
+    if (!model || !layer || !layer->ffn_exp_probs_b || il >= DS4_MAX_LAYER)
+        return 0;
+    uint32_t slot = 0;
+    while (slot < g_reap_bias_n &&
+           g_reap_bias_tensor[slot] != layer->ffn_exp_probs_b) slot++;
+    if (slot >= g_reap_bias_n || slot >= DS4_MAX_LAYER) return 0;
+    const float *orig =
+        (const float *)tensor_data(model, layer->ffn_exp_probs_b);
+    for (uint32_t e = 0; e < DS4_N_EXPERT; e++) {
+        g_reap_bias_masked[slot][e] = orig[e] +
+            (ds4_reap_mask_effectively_pruned(il, e) ? -1.0e9f : 0.0f);
+    }
+    return ds4_gpu_model_range_update(
+               model->map,
+               layer->ffn_exp_probs_b->abs_offset,
+               g_reap_bias_masked[slot],
+               (uint64_t)DS4_N_EXPERT * sizeof(float)) > 0;
+}
