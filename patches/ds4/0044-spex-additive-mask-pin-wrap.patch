+/* patch 0044: additive SPEX mask lane. The core remains K-by-mass in
+ * g_reap_mask_pruned; these are duplicate-free provisional experts on top. */
+static uint32_t ds4_spex_mask_add_cap(void) {
+    return metal_graph_spex_env_u32("DS4_PACE_LIVEMASK_SPEX_ADD", 0, 16);
+}
+
+static int ds4_spex_mask_wrap_enabled(void) {
+    static int cached = -1;
+    if (cached < 0) {
+        const char *v = getenv("DS4_PACE_LIVEMASK_SPEX_WRAP");
+        cached = v && v[0] && strcmp(v, "0") != 0;
+    }
+    return cached;
+}
+
+static FILE *ds4_spex_mask_log(void) {
+    static FILE *fh;
+    static int checked;
+    if (!checked) {
+        checked = 1;
+        const char *path = getenv("DS4_PACE_LIVEMASK_SPEX_LOG");
+        if (path && path[0]) fh = fopen(path, "w");
+    }
+    return fh;
+}
+
+static uint32_t ds4_spex_mask_update_layer(
+        const ds4_model   *model,
+        const ds4_weights *weights,
+        uint32_t           pos,
+        uint32_t           source_il,
+        uint32_t           target_il,
+        const int32_t     *ranked_ids,
+        uint32_t           ranked_n,
+        int32_t           *out_add,
+        uint32_t           out_cap) {
+    const uint32_t cap = ds4_spex_mask_add_cap();
+    if (cap == 0 || !ds4_spex_mask_core_ready() ||
+        target_il >= DS4_N_LAYER || target_il >= DS4_MAX_LAYER) {
+        return 0;
+    }
+    uint8_t next[DS4_MAX_EXPERT];
+    memset(next, 0, sizeof(next));
+    uint32_t n = 0;
+    for (uint32_t i = 0; ranked_ids && i < ranked_n && n < cap && n < out_cap; i++) {
+        const int32_t id = ranked_ids[i];
+        if (id < 0 || (uint32_t)id >= DS4_N_EXPERT) continue;
+        const uint32_t e = (uint32_t)id;
+        if (!g_reap_mask_pruned[target_il][e] || next[e]) continue;
+        next[e] = 1;
+        out_add[n++] = id;
+    }
+
+    int wrap_ready = 1;
+    double wrap_ms = 0.0;
+    if (n > 0 && ds4_spex_mask_wrap_enabled()) {
+        ds4_reap_expert_id batch[16];
+        for (uint32_t i = 0; i < n; i++) {
+            batch[i].layer = target_il;
+            batch[i].expert = (uint32_t)out_add[i];
+        }
+        const double wrap_t0 = now_sec();
+        wrap_ready = ds4_reap_prefetch_batch_sync(model, weights, batch, n);
+        wrap_ms = (now_sec() - wrap_t0) * 1000.0;
+        if (!wrap_ready) {
+            memset(next, 0, sizeof(next));
+            n = 0; /* fail closed: never expose an expert before its WRAP batch */
+        }
+    }
+
+    uint8_t *cur = g_reap_spex_pin[target_il];
+    const int changed = memcmp(cur, next, DS4_N_EXPERT) != 0;
+    if (changed) {
+        memcpy(cur, next, DS4_N_EXPERT);
+        g_reap_pin_epoch++;
+        (void)ds4_reap_mask_apply_layer(model, weights, target_il);
+    }
+
+    FILE *fh = ds4_spex_mask_log();
+    if (fh) {
+        fprintf(fh,
+                "{\"ev\":\"spex_add\",\"pos\":%u,\"source_layer\":%u,"
+                "\"target_layer\":%u,\"ranked\":%u,\"added\":%u,"
+                "\"changed\":%d,\"wrap_ready\":%d,\"wrap_ms\":%.3f,"
+                "\"ids\":[",
+                pos, source_il, target_il, ranked_n, n, changed,
+                wrap_ready, wrap_ms);
+        for (uint32_t i = 0; i < n; i++)
+            fprintf(fh, "%s%d", i ? "," : "", out_add[i]);
+        fprintf(fh, "]}\n");
+        fflush(fh);
+    }
+    return n;
+}
+
+/* End the one-layer lease after the target router has selected and its expert
+ * load has been submitted. The slot stays physically pinned until the next
+ * cache reconciliation, so an in-flight upload/compute cannot lose residency. */
+static void ds4_spex_mask_consume_layer(const ds4_model   *model,
+                                        const ds4_layer_weights *layer,
+                                        uint32_t           pos,
+                                        uint32_t           il) {
+    if (ds4_spex_mask_add_cap() == 0 || il >= DS4_MAX_LAYER) return;
+    uint8_t *row = g_reap_spex_pin[il];
+    uint32_t released = 0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT; e++) released += row[e] != 0;
+    if (released == 0) return;
+    memset(row, 0, DS4_N_EXPERT);
+    g_reap_pin_epoch++;
+    (void)ds4_reap_mask_apply_layer_direct(model, layer, il);
+    FILE *fh = ds4_spex_mask_log();
+    if (fh) {
+        fprintf(fh,
+                "{\"ev\":\"spex_consume\",\"pos\":%u,\"layer\":%u,"
+                "\"released\":%u}\n",
+                pos, il, released);
+        fflush(fh);
+    }
+}
