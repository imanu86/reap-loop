@@ -14476,13 +14528,45 @@ static void metal_graph_spex_trace_selected(
             }
         }
     }
+    if (metal_graph_spex_trace_routing_residency_enabled()) {
+        for (uint32_t i = 0; i < DS4_MAX_EXPERT_USED; i++) {
