From 3b4f9a0b6c7d8e9f00112233445566778899aabb Mon Sep 17 00:00:00 2001
From: reap-loop <reap-loop@local>
Date: Fri, 10 Jul 2026 12:00:00 +0200
Subject: [PATCH] spex: append optional routing residency trace columns

DS4_SPEX_TRACE_ROUTING_RESIDENCY=1 appends storage0..storage5 to the
existing DS4_SPEX_TRACE_ROUTING CSV.  The default CSV remains unchanged;
when weights are enabled the storage columns are appended after w0..w5,
otherwise they are appended after e0..e5.

Residency is derived from the runtime CUDA-side metadata that already
decides how routed expert weights are served: the streaming expert cache
slot table and model range cache/registration state.  No expert payloads
or GPU tensors are read back for this feature.
---
 ds4.c       |  56 ++++++++++++++++++++++++++-
 ds4_cuda.cu | 111 +++++++++++++++++++++++++++++++++++++++++++++++++++++
 ds4_gpu.h   |  16 ++++++++
 3 files changed, 182 insertions(+), 2 deletions(-)

diff --git a/ds4.c b/ds4.c
index 78cae24..b823111 100644
--- a/ds4.c
+++ b/ds4.c
@@ -14381,6 +14381,20 @@ static bool metal_graph_spex_trace_routing_weights_enabled(void) {
     return cached == 1;
 }
 
+/* DS4_SPEX_TRACE_ROUTING_RESIDENCY=1 appends storage0..storage5 after the
+ * selected expert ids, or after w0..w5 when routing weights are enabled.
+ * Values come from ds4_gpu_stream_expert_residency(), which inspects runtime
+ * cache / mapping metadata only; it does not read expert payloads back from the
+ * GPU. */
+static bool metal_graph_spex_trace_routing_residency_enabled(void) {
+    static int cached = -1;
+    if (cached < 0) {
+        const char *v = getenv("DS4_SPEX_TRACE_ROUTING_RESIDENCY");
+        cached = (v && v[0] && strcmp(v, "0") != 0) ? 1 : 0;
+    }
+    return cached == 1;
+}
