diff --git a/ds4_cuda.cu b/ds4_cuda.cu
index 68b022c..2cb91fb 100644
--- a/ds4_cuda.cu
+++ b/ds4_cuda.cu
@@ -505,6 +505,54 @@ static int cuda_model_range_is_cached(const void *model_map, uint64_t offset, ui
     return 0;
 }
 
+static ds4_gpu_expert_residency cuda_model_range_residency(
+        const void *model_map,
+        uint64_t    offset,
+        uint64_t    bytes) {
+    if (!model_map || bytes == 0) return DS4_GPU_EXPERT_RESIDENCY_UNKNOWN;
+    const uint64_t end = offset + bytes;
+    if (end < offset) return DS4_GPU_EXPERT_RESIDENCY_UNKNOWN;
+
+    if (g_model_device_owned) return DS4_GPU_EXPERT_RESIDENCY_VRAM;
+
+    for (const cuda_model_range &r : g_model_ranges) {
+        if (r.host_base != model_map) continue;
+        if (offset >= r.offset && end <= r.offset + r.bytes) {
+            return r.host_registered ?
+                DS4_GPU_EXPERT_RESIDENCY_CPU_RAM :
+                DS4_GPU_EXPERT_RESIDENCY_VRAM;
+        }
+        if (r.host_registered && r.registered_base &&
+            r.registered_device_base) {
+            const uintptr_t h0 = (uintptr_t)((const char *)model_map + offset);
+            const uintptr_t h1 = h0 + bytes;
+            const uintptr_t r0 = (uintptr_t)r.registered_base;
+            const uintptr_t r1 = r0 + r.registered_bytes;
+            if (h1 >= h0 && h0 >= r0 && h1 <= r1) {
+                return DS4_GPU_EXPERT_RESIDENCY_CPU_RAM;
+            }
+        }
+    }
+
+    if (g_model_registered || g_model_hmm_direct ||
+        getenv("DS4_CUDA_DIRECT_MODEL") != NULL) {
+        return DS4_GPU_EXPERT_RESIDENCY_CPU_RAM;
+    }
+
+    if (g_ssd_streaming_mode &&
+        g_model_fd >= 0 &&
+        (g_model_fd_host_base == NULL || model_map == g_model_fd_host_base)) {
+        return DS4_GPU_EXPERT_RESIDENCY_SSD_OFFLOAD;
+    }
+
+    return DS4_GPU_EXPERT_RESIDENCY_UNKNOWN;
+}
+
+static ds4_gpu_expert_residency cuda_model_ranges_residency3(
+        const void *model_map,
+        uint64_t    gate_offset,
+        uint64_t    up_offset,
+        uint64_t    down_offset,
+        uint64_t    gate_expert_bytes,
+        uint64_t    down_expert_bytes) {
+    ds4_gpu_expert_residency a =
+        cuda_model_range_residency(model_map, gate_offset, gate_expert_bytes);
+    ds4_gpu_expert_residency b =
+        cuda_model_range_residency(model_map, up_offset, gate_expert_bytes);
+    ds4_gpu_expert_residency c =
+        cuda_model_range_residency(model_map, down_offset, down_expert_bytes);
+    if (a == DS4_GPU_EXPERT_RESIDENCY_VRAM &&
+        b == DS4_GPU_EXPERT_RESIDENCY_VRAM &&
+        c == DS4_GPU_EXPERT_RESIDENCY_VRAM) {
+        return DS4_GPU_EXPERT_RESIDENCY_VRAM;
+    }
+    if (a == DS4_GPU_EXPERT_RESIDENCY_UNKNOWN ||
+        b == DS4_GPU_EXPERT_RESIDENCY_UNKNOWN ||
+        c == DS4_GPU_EXPERT_RESIDENCY_UNKNOWN) {
+        return DS4_GPU_EXPERT_RESIDENCY_UNKNOWN;
+    }
+    if (a == DS4_GPU_EXPERT_RESIDENCY_SSD_OFFLOAD ||
+        b == DS4_GPU_EXPERT_RESIDENCY_SSD_OFFLOAD ||
+        c == DS4_GPU_EXPERT_RESIDENCY_SSD_OFFLOAD) {
+        return DS4_GPU_EXPERT_RESIDENCY_SSD_OFFLOAD;
+    }
+    return DS4_GPU_EXPERT_RESIDENCY_CPU_RAM;
+}
+
 static int cuda_model_range_is_cached(const void *model_map, uint64_t offset, uint64_t bytes) {
     if (bytes == 0) return 1;
     if (g_model_device_owned || g_model_registered || g_model_hmm_direct) return 1;
@@ -2034,6 +2082,29 @@ static int cuda_stream_expert_cache_find(
     return -1;
 }
 
+static int cuda_stream_expert_cache_contains_table(
+        const cuda_stream_expert_cache       *cache,
+        const ds4_gpu_stream_expert_table    *table,
+        uint32_t                              expert) {
+    if (!cache || !table || !cache->valid || cache->capacity == 0) return 0;
+    for (uint32_t slot_i = 0; slot_i < cache->capacity; slot_i++) {
+        const cuda_stream_expert_cache_slot &slot = cache->slots[slot_i];
+        if (slot.valid &&
+            slot.model_map == table->model_map &&
+            slot.model_size == table->model_size &&
+            slot.layer == table->layer &&
+            slot.n_total_expert == table->n_total_expert &&
+            slot.expert == expert &&
+            slot.gate_offset == table->gate_offset &&
+            slot.up_offset == table->up_offset &&
+            slot.down_offset == table->down_offset &&
+            slot.gate_expert_bytes == table->gate_expert_bytes &&
+            slot.down_expert_bytes == table->down_expert_bytes) {
+            return 1;
+        }
+    }
+    return 0;
+}
+
 static uint32_t cuda_stream_expert_cache_lru_slot(
         cuda_stream_expert_cache *cache) {
     for (uint32_t i = 0; i < cache->capacity; i++) {
@@ -3476,6 +3547,46 @@ extern "C" uint32_t ds4_gpu_stream_expert_cache_budget_for_expert_size(
     return cuda_stream_expert_cache_configured_budget();
 }
 
+extern "C" ds4_gpu_expert_residency ds4_gpu_stream_expert_residency(
+        const ds4_gpu_stream_expert_table *table,
+        uint32_t                           expert) {
+    if (!table ||
+        !table->model_map ||
+        expert >= table->n_total_expert ||
+        !cuda_stream_layer_expert_ranges_valid(table->model_size,
+                                               table->n_total_expert,
+                                               table->gate_offset,
+                                               table->up_offset,
+                                               table->down_offset,
+                                               table->gate_expert_bytes,
+                                               table->down_expert_bytes,
+                                               "trace residency")) {
+        return DS4_GPU_EXPERT_RESIDENCY_UNKNOWN;
+    }
+
+    if (cuda_stream_expert_cache_contains_table(&g_stream_expert_cache,
+                                                table,
+                                                expert)) {
+        return DS4_GPU_EXPERT_RESIDENCY_VRAM;
+    }
+
+    const uint64_t gate_offset =
+        table->gate_offset + (uint64_t)expert * table->gate_expert_bytes;
+    const uint64_t up_offset =
+        table->up_offset + (uint64_t)expert * table->gate_expert_bytes;
+    const uint64_t down_offset =
+        table->down_offset + (uint64_t)expert * table->down_expert_bytes;
+    return cuda_model_ranges_residency3(table->model_map,
+                                        gate_offset,
+                                        up_offset,
+                                        down_offset,
+                                        table->gate_expert_bytes,
+                                        table->down_expert_bytes);
+}
+
 extern "C" uint32_t ds4_gpu_stream_expert_cache_count_resident(
         const ds4_gpu_stream_expert_table *table,
         const int32_t                     *expert_ids,
