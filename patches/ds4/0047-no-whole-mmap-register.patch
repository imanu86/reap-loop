+static int cuda_stream_selected_stage_depth(void) {
+    if (g_stream_selected_stage_depth_cached < 0) {
+        int depth = 4;
+        const char *env = getenv("DS4_CUDA_SELECTED_STAGE_DEPTH");
+        if (env && env[0]) {
+            char *end = NULL;
+            long v = strtol(env, &end, 10);
+            if (end != env && v >= 1 && v <= DS4_STREAM_SELECTED_STAGE_MAX) {
+                depth = (int)v;
+            } else if (end != env) {
+                fprintf(stderr,
+                        "ds4: DS4_CUDA_SELECTED_STAGE_DEPTH=%s out of range "
+                        "[1,%d], using default %d\n",
+                        env, DS4_STREAM_SELECTED_STAGE_MAX, depth);
+            }
+        }
+        g_stream_selected_stage_depth_cached = depth;
+    }
+    return g_stream_selected_stage_depth_cached;
