+/* ---- patch 0022: S1-rewind frontier snapshot/restore (dedicated buffers) ----
+ * Graph-level twins of spec_frontier_snapshot/restore that target the
+ * DS4_PACE_REWIND-gated g->spec_rewind_* set (not the MTP spec_* buffers the
+ * speculative verifier reuses every token) and take a bare ds4_gpu_graph, so
+ * BOTH the session path and the greedy CLI loop (which owns no ds4_session)
+ * drive them. Counters live inline in g_rewind (no ds4_spec_frontier type in
+ * the host detector block). */
+static bool ds4_pace_rewind_snapshot_frontier(ds4_gpu_graph *g, uint32_t slot) {
+    /* Flash: layers 0-1 are dense (ratio==0), so spec_rewind_attn_state_kv[0]
+     * is never allocated (gated on ratio!=0 at alloc, ds4.c:11326) and a
+     * literal index-0 probe is permanently NULL. Scan for the first
+     * *allocated* rewind buffer instead, mirroring how the loop below (and
+     * the MTP twin spec_frontier_snapshot) already skips dense layers. */
+    bool have_buf = false;
+    for (uint32_t il = 0; il < DS4_N_LAYER; il++) {
+        if (g->spec_rewind_attn_state_kv[slot][il]) { have_buf = true; break; }
+    }
+    if (!have_buf) return false;
+    bool ok = ds4_gpu_begin_commands() != 0;
+    g_rewind.rw_mtp_n_raw[slot] = g->mtp_n_raw;
+    for (uint32_t il = 0; ok && il < DS4_N_LAYER; il++) {
+        g_rewind.rw_n_comp[slot][il] = g->layer_n_comp[il];
+        g_rewind.rw_n_index_comp[slot][il] = g->layer_n_index_comp[il];
+        const uint32_t ratio = ds4_layer_compress_ratio(il);
+        if (ratio == 0) continue;
+        const uint64_t ab = ds4_gpu_tensor_bytes(g->layer_attn_state_kv[il]);
+        ok = ds4_gpu_tensor_copy(g->spec_rewind_attn_state_kv[slot][il], 0,
+                                   g->layer_attn_state_kv[il], 0, ab) != 0 &&
+             ds4_gpu_tensor_copy(g->spec_rewind_attn_state_score[slot][il], 0,
+                                   g->layer_attn_state_score[il], 0, ab) != 0;
+        if (ok && ratio == 4) {
+            const uint64_t ib = ds4_gpu_tensor_bytes(g->layer_index_state_kv[il]);
+            ok = ds4_gpu_tensor_copy(g->spec_rewind_index_state_kv[slot][il], 0,
+                                       g->layer_index_state_kv[il], 0, ib) != 0 &&
+                 ds4_gpu_tensor_copy(g->spec_rewind_index_state_score[slot][il], 0,
+                                       g->layer_index_state_score[il], 0, ib) != 0;
+        }
+    }
+    if (ok) ok = ds4_gpu_end_commands() != 0;
+    else (void)ds4_gpu_synchronize();
+    return ok;
