 /* Later layers choose the six experts by biased top-k, but weight them using
  * the unbiased router probabilities. */
+/* ---- patch 0011 v2: REAP runtime mask (DS4_REAP_MASK_FILE) ----
+ * File: righe "<layer> <expert>" = potato. mtime-poll a ogni token decode.
+ * GPU: upsert di range device per i bias (vince sul fallback registered).
+ * CPU: override del bias in layer_topk_selected_experts_from_probs. */
+static char *g_reap_mask_path;
+static long g_reap_mask_mtime_s = -1;
+static long g_reap_mask_mtime_ns = -1;
+static bool g_reap_mask_env_checked;
+static bool g_reap_mask_on;
+static uint8_t g_reap_mask_pruned[DS4_MAX_LAYER][DS4_MAX_EXPERT];
+static float g_reap_bias_masked[DS4_MAX_LAYER][DS4_MAX_EXPERT];
+static const void *g_reap_bias_tensor[DS4_MAX_LAYER];
+static uint32_t g_reap_bias_n;
+
+static const float *ds4_reap_mask_cpu_bias(const void *bias_tensor) {
+    if (!g_reap_mask_on || !bias_tensor) return NULL;
+    for (uint32_t i = 0; i < g_reap_bias_n; i++) {
+        if (g_reap_bias_tensor[i] == bias_tensor) return g_reap_bias_masked[i];
+    }
+    return NULL;
+}
+
+static void ds4_reap_mask_apply(const ds4_model *model, const ds4_weights *weights) {
+    uint32_t slot = 0, ranges_updated = 0;
+    for (uint32_t il = 0; il < DS4_N_LAYER && slot < DS4_MAX_LAYER; il++) {
+        const ds4_layer_weights *layer = &weights->layer[il];
+        if (!layer->ffn_exp_probs_b) continue;
+        const float *orig = (const float *)tensor_data(model, layer->ffn_exp_probs_b);
+        for (uint32_t e = 0; e < DS4_N_EXPERT; e++) {
+            g_reap_bias_masked[slot][e] = orig[e] + (g_reap_mask_pruned[il][e] ? -1.0e9f : 0.0f);
+        }
+        g_reap_bias_tensor[slot] = layer->ffn_exp_probs_b;
+        int upd = ds4_gpu_model_range_update(model->map,
+                                             layer->ffn_exp_probs_b->abs_offset,
+                                             g_reap_bias_masked[slot],
+                                             (uint64_t)DS4_N_EXPERT * sizeof(float));
+        ranges_updated += (uint32_t)(upd > 0 ? upd : 0);
+        slot++;
+    }
+    g_reap_bias_n = slot;
+    g_reap_mask_on = true;
+    fprintf(stderr, "ds4: REAP mask applied: %u layer, %u device range aggiornati/creati\n",
+            slot, ranges_updated);
+}
+
+static void ds4_reap_mask_poll(const ds4_model *model, const ds4_weights *weights) {
+    if (!g_reap_mask_env_checked) {
+        g_reap_mask_env_checked = true;
+        const char *p = getenv("DS4_REAP_MASK_FILE");
+        if (p && *p) g_reap_mask_path = ds4_strdup(p);
+    }
+    if (!g_reap_mask_path || !model || !weights) return;
+    /* v3: re-apply periodico - l'upsert puo' venire soppiantato da range registrati
+     * DOPO l'apply (model-load in corso nei primi token): riconquista l'indice. */
+    {
+        static uint32_t poll_n;
+        if (g_reap_mask_on && (++poll_n % 32u) == 0u) ds4_reap_mask_apply(model, weights);
+    }
+    struct stat st;
+    if (stat(g_reap_mask_path, &st) != 0) return;
+    if ((long)st.st_mtim.tv_sec == g_reap_mask_mtime_s &&
+        (long)st.st_mtim.tv_nsec == g_reap_mask_mtime_ns) return;
+    g_reap_mask_mtime_s = (long)st.st_mtim.tv_sec;
+    g_reap_mask_mtime_ns = (long)st.st_mtim.tv_nsec;
+    memset(g_reap_mask_pruned, 0, sizeof(g_reap_mask_pruned));
+    FILE *f = fopen(g_reap_mask_path, "r");
+    if (!f) return;
+    unsigned l, e, count = 0;
+    while (fscanf(f, "%u %u", &l, &e) == 2) {
+        if (l < DS4_MAX_LAYER && e < DS4_MAX_EXPERT) { g_reap_mask_pruned[l][e] = 1; count++; }
+    }
+    fclose(f);
+    fprintf(stderr, "ds4: REAP mask reload da %s: %u entry potate\n", g_reap_mask_path, count);
+    ds4_reap_mask_apply(model, weights);
+}
