+static FILE *g_spex_trace_routing_fh;
+static char *g_spex_trace_routing_path;
+static bool g_spex_trace_routing_failed;
+
+static FILE *metal_graph_spex_trace_routing_file(void) {
+    if (g_spex_trace_routing_failed) return NULL;
+    const char *path = getenv("DS4_SPEX_TRACE_ROUTING");
+    if (!path || !path[0]) return NULL;
+    if (g_spex_trace_routing_fh) return g_spex_trace_routing_fh;
+
+    g_spex_trace_routing_fh = fopen(path, "w");
+    if (!g_spex_trace_routing_fh) {
+        fprintf(stderr,
+                "ds4: cannot open DS4_SPEX_TRACE_ROUTING '%s': %s\n",
+                path,
+                strerror(errno));
+        g_spex_trace_routing_failed = true;
+        return NULL;
+    }
+    g_spex_trace_routing_path = ds4_strdup(path);
+    fprintf(g_spex_trace_routing_fh,
+            "pos,layer,n,e0,e1,e2,e3,e4,e5\n");
+    fprintf(stderr, "ds4: SPEX routing trace enabled: %s\n", path);
+    return g_spex_trace_routing_fh;
+}
+
+static void metal_graph_spex_trace_selected(
+        const ds4_gpu_graph *g,
+        uint32_t             il,
+        const int32_t       *selected_ids,
+        uint32_t             n_selected) {
+    if (!g || !g->spex_trace_decode_active || !selected_ids ||
+        n_selected == 0 || n_selected > DS4_MAX_EXPERT_USED) {
+        return;
+    }
+    for (uint32_t i = 0; i < n_selected; i++) {
+        if (selected_ids[i] < 0 || (uint32_t)selected_ids[i] >= DS4_N_EXPERT) {
+            return;
+        }
+    }
+    FILE *fh = metal_graph_spex_trace_routing_file();
+    if (!fh) return;
+    fprintf(fh,
+            "%u,%u,%u",
+            g->spex_trace_pos,
+            il,
+            n_selected);
+    for (uint32_t i = 0; i < DS4_MAX_EXPERT_USED; i++) {
+        const int32_t eid = i < n_selected ? selected_ids[i] : -1;
+        fprintf(fh, ",%d", eid);
+    }
+    fputc('\n', fh);
+}
