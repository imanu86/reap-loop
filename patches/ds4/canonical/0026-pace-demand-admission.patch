             ds4_pace_note_router_probs(il, probs);
             ds4_pace_s1_note_probs(il, probs);
+            ds4_pace_admit_note_probs(il, probs);
         }
     }
     /* PACE (0014): in-memory gate-mass + hit-rate, including prefill.
