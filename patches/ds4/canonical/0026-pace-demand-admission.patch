 }
 
+/* ---- demand-driven admission CUSUM (patch 0026) ---- *
+ * Per (layer, PRUNED expert): CUSUM of the per-token requested share of the
+ * non-biased router mass, S <- max(0, S + share - k_drift), plus an
+ * excursion-length counter. Fed from the same raw-router readback as the
+ * 0020 rmass. This hook only ACCUMULATES; the threshold test and the physical
+ * targeted swap happen once per token in ds4_pace_tick. */
+static void ds4_pace_admit_note_probs(uint32_t il, const float *probs) {
+    if (!probs || il >= DS4_MAX_LAYER || !g_pace.admit_cusum ||
+        !ds4_pace_admit_wants_router())
+        return;
+    double tot = 0.0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++)
+        tot += (double)probs[e];
+    if (tot <= 0.0) return;
+    const double kd = g_pace.admit_kdrift;
+    double  *S = &g_pace.admit_cusum[(size_t)il * DS4_MAX_EXPERT];
+    uint32_t *P = &g_pace.admit_persist_ct[(size_t)il * DS4_MAX_EXPERT];
+    for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+        if (!g_reap_mask_pruned[il][e]) { S[e] = 0.0; P[e] = 0; continue; }
+        const double s = S[e] + (double)probs[e] / tot - kd;
+        if (s <= 0.0) { S[e] = 0.0; P[e] = 0; }
+        else { S[e] = s; P[e]++; }
+    }
+}
