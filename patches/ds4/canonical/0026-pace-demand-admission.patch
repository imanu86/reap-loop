+/* ---- demand-driven admission scan (patch 0026) ---- *
+ * Once per decode token in PACE_HOLD: for each layer, if a PRUNED expert's
+ * CUSUM crossed the threshold with enough persistence, ADMIT it by evicting
+ * the KEPT expert with the least rmass EWMA (constant K), honoring the
+ * anti-thrash cooldown and the optional per-100-tok rate cap. The physical
+ * page-in reuses the 0021 delta-prefetch (only the entered experts, ~6.75
+ * MiB each). Never K0, never wholesale re-ranking. Returns the number of
+ * admissions this token. */
+static int ds4_pace_admit_scan(const ds4_model *model, const ds4_weights *weights) {
+    if (!g_pace.admit_on || !g_pace.admit_cusum || !g_pace.rmass ||
+        g_pace.phase != PACE_HOLD || g_pace.cur_keep <= 0 || !g_reap_mask_on)
+        return 0;
+    /* fixed-window rate cap (optional): roll the window every 100 tok */
+    if (g_pace.admit_max_per_100 > 0 &&
+        g_pace.tok - g_pace.admit_win_start >= 100) {
+        g_pace.admit_win_start = g_pace.tok;
+        g_pace.admit_win_count = 0;
+    }
+    uint8_t old_pruned[DS4_MAX_LAYER][DS4_MAX_EXPERT];
+    int snapped = 0, did = 0;
+    for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER; il++) {
+        if (g_pace.admit_max_per_100 > 0 &&
+            g_pace.admit_win_count >= g_pace.admit_max_per_100)
+            break;
+        const size_t base = (size_t)il * DS4_MAX_EXPERT;
+        const double  *S = &g_pace.admit_cusum[base];
+        const uint32_t *P = &g_pace.admit_persist_ct[base];
+        /* strongest pruned expert past threshold + persistence */
+        int adm = -1; double adm_S = g_pace.admit_h;
+        for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+            if (!g_reap_mask_pruned[il][e]) continue;
+            if (P[e] < g_pace.admit_persist) continue;
+            if (S[e] >= adm_S) { adm_S = S[e]; adm = (int)e; }
+        }
+        if (adm < 0) continue;
+        /* eviction victim: least-rmass keep that is past its cooldown */
+        const double  *M = &g_pace.rmass[base];
+        const uint32_t *LT = &g_pace.admit_last_tok[base];
+        int vic = -1; double vic_m = 0.0;
+        for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+            if (g_reap_mask_pruned[il][e]) continue;              /* kept only */
+            if (g_pace.tok - LT[e] < g_pace.admit_cooldown) continue; /* protected */
+            if (vic < 0 || M[e] < vic_m) { vic_m = M[e]; vic = (int)e; }
+        }
+        if (vic < 0) continue;   /* every keep still cooling down */
+        if (!snapped) {
+            memcpy(old_pruned, g_reap_mask_pruned, sizeof(old_pruned));
+            snapped = 1;
+        }
+        /* targeted swap, K unchanged */
+        g_reap_mask_pruned[il][vic] = 1;
+        g_reap_mask_pruned[il][adm] = 0;
+        g_pace.admit_cusum[base + (uint32_t)adm] = 0.0;
+        g_pace.admit_persist_ct[base + (uint32_t)adm] = 0;
+        g_pace.admit_cusum[base + (uint32_t)vic] = 0.0;
+        g_pace.admit_persist_ct[base + (uint32_t)vic] = 0;
+        g_pace.admit_last_tok[base + (uint32_t)adm] = g_pace.tok;
+        g_pace.admit_events++;
+        g_pace.admit_win_count++;
+        if (g_pace.evlog) {
+            fprintf(g_pace.evlog,
+                "{\"ev\":\"admit\",\"tok\":%u,\"layer\":%u,\"expert\":%d,"
+                "\"evicted\":%d,\"cusum\":%.5f,\"keep\":%d}\n",
+                g_pace.tok, il, adm, vic, adm_S, g_pace.cur_keep);
+            fflush(g_pace.evlog);
+        }
+        if (g_pace.debug) {
+            fprintf(stderr,
+                "ds4: PACE admit tok=%u L%u e%d<-evict e%d S=%.4f\n",
+                g_pace.tok, il, adm, vic, adm_S);
+        }
+        did++;
+    }
+    if (did) {
+        ds4_reap_mask_apply(model, weights);                        /* 0011 */
+        ds4_reap_prefetch_rotate_delta(model, weights, old_pruned); /* 0021 */
+    }
+    return did;
+}
