+
+static void metal_graph_spex_note_selected(
+        ds4_gpu_graph *g,
+        uint32_t       il,
+        const int32_t *selected_ids,
+        uint32_t       n_selected) {
+    if (!metal_graph_spex_prefetch_next_layer_enabled(g)) return;
+    g->spex_prefetch_selected_valid = false;
+    if (!selected_ids ||
+        n_selected == 0 ||
+        n_selected > DS4_MAX_EXPERT_USED) {
+        return;
+    }
+    for (uint32_t i = 0; i < n_selected; i++) {
+        if (selected_ids[i] < 0 || (uint32_t)selected_ids[i] >= DS4_N_EXPERT) {
+            return;
+        }
+        g->spex_prefetch_selected[i] = selected_ids[i];
+    }
+    g->spex_prefetch_selected_layer = il;
+    g->spex_prefetch_selected_count = n_selected;
+    g->spex_prefetch_selected_valid = true;
+}
+
+static bool metal_graph_spex_prefetch_next_layer(
+        ds4_gpu_graph     *g,
+        const ds4_model   *model,
+        const ds4_weights *weights,
+        uint32_t           il) {
+#if !defined(DS4_ROCM_BUILD) && !defined(DS4_NO_GPU) && !defined(__APPLE__)
+    if (!metal_graph_spex_prefetch_next_layer_enabled(g)) return true;
+    if (!model || !weights || !g->spex_prefetch_selected_valid ||
+        g->spex_prefetch_selected_layer != il) {
+        return true;
+    }
+    g->spex_prefetch_selected_valid = false;
+    if (il + 1u >= DS4_N_LAYER) return true;
+
+    const uint32_t next_il = il + 1u;
+    const ds4_layer_weights *next_layer = &weights->layer[next_il];
+    if (!metal_graph_decode_cuda_selected_slots_expected(g, next_layer) ||
+        next_layer->ffn_gate_tid2eid != NULL) {
+        return true;
+    }
+
+    uint64_t gate_expert_bytes = 0;
+    uint64_t down_expert_bytes = 0;
+    if (!streaming_layer_gate_down_expert_bytes(next_layer,
+                                                &gate_expert_bytes,
+                                                &down_expert_bytes)) {
+        return false;
+    }
+
+    const ds4_gpu_stream_expert_table table =
+        graph_stream_expert_table_make(model,
+                                       next_layer,
+                                       next_il,
+                                       gate_expert_bytes,
+                                       down_expert_bytes);
+    const bool ok = ds4_gpu_stream_expert_cache_seed_experts_async(
+                        &table,
+                        g->spex_prefetch_selected,
+                        NULL,
+                        g->spex_prefetch_selected_count) != 0;
+    if (getenv("DS4_SPEX_PREFETCH_PROFILE")) {
+        fprintf(stderr,
+                "ds4: SPEX stage1 prefetch L%u->L%u experts=%u ok=%d\n",
+                il,
+                next_il,
+                g->spex_prefetch_selected_count,
+                ok ? 1 : 0);
+    }
+    return ok;
+#else
+    (void)g;
+    (void)model;
+    (void)weights;
+    (void)il;
+    return true;
+#endif
+}
