+static uint16_t cuda_expert_cold_f32_to_f16(float v) {
+    __half h = __float2half(v);
+    uint16_t bits = 0;
+    memcpy(&bits, &h, sizeof(bits));
+    return bits;
+}
+
+static float cuda_expert_cold_f16_to_f32(uint16_t bits) {
+    __half h;
+    memcpy(&h, &bits, sizeof(h));
+    return __half2float(h);
+}
