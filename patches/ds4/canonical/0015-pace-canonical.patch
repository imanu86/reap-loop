+#if !defined(DS4_ROCM_BUILD) && !defined(DS4_NO_GPU) && !defined(__APPLE__)
+    if (!g || !out_ids || out_cap == 0 ||
+        !g->spex_hidden_topk ||
+        !g->spex_hidden_topk_readback ||
+        !g->spex_hidden_gpu_topk_valid ||
+        g->spex_hidden_gpu_topk_layer != il ||
+        g->spex_hidden_gpu_topk_count == 0) {
+        return 0;
+    }
+    uint32_t n = g->spex_hidden_gpu_topk_count;
+    if (n > out_cap) n = out_cap;
+    if (n > DS4_MAX_EXPERT) n = DS4_MAX_EXPERT;
+    if (!ds4_gpu_async_read_ready(g->spex_hidden_topk_readback)) {
+        metal_graph_spex_hidden_gpu_prefetch_stats_touch();
