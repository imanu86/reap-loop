+
+static uint32_t metal_graph_spex_hidden_predict_cpu(
+        const ds4_spex_hidden_params *p,
+        uint32_t                      il,
+        const float                  *hidden,
+        int32_t                      *out_ids,
+        uint32_t                      out_cap) {
+    if (!p || !p->weights || !hidden || !out_ids || out_cap == 0 ||
+        il + 1u >= p->n_layer ||
+        p->n_embd != DS4_N_EMBD ||
+        p->n_expert == 0 ||
+        p->n_expert > DS4_MAX_EXPERT) {
+        return 0;
+    }
+    const uint32_t cap = metal_graph_spex_hidden_cap(out_cap);
+    if (cap == 0) return 0;
+    float score[DS4_MAX_EXPERT];
+    bool picked[DS4_MAX_EXPERT];
+    memset(score, 0, sizeof(score));
+    memset(picked, 0, sizeof(picked));
+
+    const uint16_t *w = p->weights +
+        (uint64_t)il * p->n_embd * p->n_expert;
+    for (uint32_t i = 0; i < p->n_embd; i++) {
+        const float hi = hidden[i];
+        if (hi == 0.0f) continue;
+        const uint16_t *row = w + (uint64_t)i * p->n_expert;
+        for (uint32_t e = 0; e < p->n_expert; e++) {
+            score[e] += hi * f16_to_f32(row[e]);
+        }
+    }
+
+    uint32_t n_out = 0;
+    while (n_out < cap) {
+        int32_t best = -1;
+        float best_score = -INFINITY;
+        for (uint32_t e = 0; e < p->n_expert; e++) {
+            const float s = score[e];
+            if (picked[e] || !isfinite(s)) continue;
+            if (best < 0 || s > best_score ||
+                (s == best_score && e < (uint32_t)best)) {
+                best = (int32_t)e;
+                best_score = s;
+            }
+        }
+        if (best < 0) break;
+        picked[(uint32_t)best] = true;
+        out_ids[n_out++] = best;
+    }
+    return n_out;
+}
