+static int ds4_env_truthy(const char *name) {
+    const char *v = getenv(name);
+    return v && v[0] && strcmp(v, "0") != 0;
+}
+
+static uint32_t ds4_env_u32(const char *name, uint32_t dflt) {
+    const char *v = getenv(name);
+    if (!v || !v[0]) return dflt;
+    char *end = NULL;
+    errno = 0;
+    unsigned long x = strtoul(v, &end, 10);
+    while (end && (*end == ' ' || *end == '\t')) end++;
+    if (end == v || errno != 0 || !end || *end != '\0') return dflt;
+    return x > UINT32_MAX ? UINT32_MAX : (uint32_t)x;
+}
+
+static uint32_t ds4_streaming_cache_token_working_set_slots(void) {
+    const uint64_t slots = (uint64_t)DS4_N_LAYER * (uint64_t)DS4_N_EXPERT_USED;
+    return slots > UINT32_MAX ? UINT32_MAX : (uint32_t)slots;
+}
+
+static void ds4_engine_apply_pace_cache_floor(ds4_engine *e) {
+#ifdef DS4_NO_GPU
+    (void)e;
+#else
+    if (!e || !e->ssd_streaming || !ds4_backend_supports_ssd_streaming(e->backend)) {
+        return;
+    }
+    if (!ds4_env_truthy("DS4_PACE") && !ds4_env_truthy("DS4_PACE_CACHE_FLOOR")) {
+        return;
+    }
+
+    uint32_t target = ds4_env_u32("DS4_PACE_CACHE_TARGET_SLOTS", 0);
+    if (target == 0) target = ds4_streaming_cache_token_working_set_slots();
+    const uint64_t max_slots = (uint64_t)DS4_N_LAYER * (uint64_t)DS4_N_EXPERT;
+    if (target == 0 || max_slots == 0) return;
+    if ((uint64_t)target > max_slots) target = max_slots > UINT32_MAX ? UINT32_MAX : (uint32_t)max_slots;
+
+    uint64_t per_expert_bytes = 0;
+    if (!ds4_streaming_routed_expert_bytes(&e->weights, &per_expert_bytes) ||
+        per_expert_bytes == 0) {
+        return;
+    }
+
+    if (e->ssd_streaming_cache_experts < target) {
+        const uint32_t before = e->ssd_streaming_cache_experts;
+        const double need_gib =
+            (double)((uint64_t)target * per_expert_bytes) / 1073741824.0;
+        if (ds4_env_truthy("DS4_PACE_CACHE_FLOOR")) {
+            e->ssd_streaming_cache_experts = target;
+            fprintf(stderr,
+                    "ds4: PACE cache floor raised resident expert budget %u -> %u "
+                    "(token working-set floor, %.2f GiB at %.2f MiB/expert)\n",
+                    before,
+                    target,
+                    need_gib,
+                    (double)per_expert_bytes / 1048576.0);
+        } else {
+            fprintf(stderr,
+                    "ds4: PACE cache diagnostic: resident expert budget %u < token "
+                    "working-set floor %u (%.2f GiB at %.2f MiB/expert); "
+                    "set DS4_PACE_CACHE_FLOOR=1 or --ssd-streaming-cache-experts %u "
+                    "to avoid guaranteed cache thrash\n",
+                    before,
+                    target,
+                    need_gib,
+                    (double)per_expert_bytes / 1048576.0,
+                    target);
+        }
+    }
+#endif
+}
