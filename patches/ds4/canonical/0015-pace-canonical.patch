+    for (uint32_t i = 0; i < n; i++) {
+        if (tmp[i] >= DS4_N_EXPERT) continue;
+        bool seen = false;
+        for (uint32_t j = 0; j < out_n; j++) {
+            if ((uint32_t)out_ids[j] == tmp[i]) {
+                seen = true;
+                break;
+            }
+        }
+        if (!seen) out_ids[out_n++] = (int32_t)tmp[i];
+    }
+    g->spex_hidden_gpu_topk_valid = false;
+    return out_n;
+#else
+    (void)g;
+    (void)il;
+    (void)out_ids;
+    (void)out_cap;
+    return 0;
+#endif
+}
