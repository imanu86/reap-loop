+static inline int ds4_pace_wants_selected_weights(void) {
+    if (!ds4_pace_active()) return 0;
+    if (g_pace.phase == PACE_WARMUP) return g_pace.weighted_warmup != 0;
+    if (g_pace.phase == PACE_HOLD)
