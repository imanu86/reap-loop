+static bool metal_graph_spex_hidden_score_gpu(
+        ds4_gpu_graph *g,
+        uint32_t       il) {
+#if !defined(DS4_ROCM_BUILD) && !defined(DS4_NO_GPU) && !defined(__APPLE__)
+    if (!metal_graph_spex_hidden_gpu_score_enabled()) return true;
+    if (!g || !g->ffn_norm || !g->spex_hidden_scores || !g->spex_hidden_topk) {
+        return false;
+    }
+    g->spex_hidden_gpu_topk_valid = false;
+    const ds4_spex_hidden_params *p = metal_graph_spex_hidden_params();
+    if (!p || !p->gpu_weights) return true;
+    if (il + 1u >= p->n_layer ||
+        p->n_embd != DS4_N_EMBD ||
+        p->n_expert == 0 ||
+        p->n_expert > DS4_MAX_EXPERT) {
+        return true;
+    }
+
+    const uint32_t cap = metal_graph_spex_hidden_cap(p->n_expert);
+    if (cap == 0) return true;
+    const uint64_t layer_weight_bytes =
+        (uint64_t)p->n_embd * p->n_expert * sizeof(uint16_t);
+    const uint64_t layer_weight_off = (uint64_t)il * layer_weight_bytes;
+    ds4_gpu_tensor *layer_weights =
+        ds4_gpu_tensor_view(p->gpu_weights, layer_weight_off, layer_weight_bytes);
+    if (!layer_weights) return false;
+
+    bool ok = ds4_gpu_spex_hidden_score_tensor(g->spex_hidden_scores,
+                                               layer_weights,
+                                               p->n_embd,
+                                               p->n_expert,
+                                               g->ffn_norm) != 0;
+    if (ok) {
+        ok = ds4_gpu_indexer_topk_tensor(g->spex_hidden_topk,
+                                         g->spex_hidden_scores,
+                                         p->n_expert,
+                                         1,
+                                         cap) != 0;
+    }
+    ds4_gpu_tensor_free(layer_weights);
+    if (!ok) return false;
+    if (metal_graph_spex_hidden_gpu_prefetch_enabled() &&
+        il + 1u < DS4_N_LAYER) {
+        if (g->spex_hidden_topk_readback &&
+            ds4_gpu_tensor_read_async(g->spex_hidden_topk_readback,
+                                      g->spex_hidden_topk,
+                                      0,
+                                      (uint64_t)cap * sizeof(uint32_t)) != 0) {
+            metal_graph_spex_hidden_gpu_prefetch_stats_touch();
+            g_spex_hidden_gpu_prefetch_stats.scheduled++;
+            g->spex_hidden_gpu_topk_layer = il;
+            g->spex_hidden_gpu_topk_count = cap;
+            g->spex_hidden_gpu_topk_valid = true;
+        } else {
+            metal_graph_spex_hidden_gpu_prefetch_stats_touch();
+            g_spex_hidden_gpu_prefetch_stats.schedule_failed++;
+            static bool warned;
+            if (!warned) {
+                fprintf(stderr,
+                        "ds4: SPEX hidden GPU topK async readback not scheduled "
+                        "(reported once)\n");
+                warned = true;
+            }
+        }
+    } else if (metal_graph_spex_hidden_gpu_prefetch_enabled()) {
+        g->spex_hidden_gpu_topk_valid = false;
+    } else {
+        g->spex_hidden_gpu_topk_layer = il;
+        g->spex_hidden_gpu_topk_count = cap;
+        g->spex_hidden_gpu_topk_valid = true;
+    }
+
+    static bool logged;
+    if (!logged) {
+        fprintf(stderr,
+                "ds4: SPEX hidden GPU scoring active cap=%u "
+                "(hidden-prefetch=%s gpu-prefetch=%s)\n",
+                cap,
+                metal_graph_spex_hidden_prefetch_enabled() ? "on" : "off",
+                metal_graph_spex_hidden_gpu_prefetch_enabled() ? "on" : "off");
+        logged = true;
+    }
+    return true;
+#else
+    (void)g;
+    (void)il;
+    return true;
+#endif
+}
