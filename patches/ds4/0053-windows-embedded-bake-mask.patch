+static uint32_t ds4_read_le32(const uint8_t *p) {
+    return ((uint32_t)p[0]) |
+           ((uint32_t)p[1] << 8) |
+           ((uint32_t)p[2] << 16) |
+           ((uint32_t)p[3] << 24);
+}
+
+static uint64_t ds4_read_le64(const uint8_t *p) {
+    return ((uint64_t)ds4_read_le32(p)) |
+           ((uint64_t)ds4_read_le32(p + 4) << 32);
+}
+
+static uint32_t ds4_crc32_update(uint32_t crc, const uint8_t *data, uint64_t len) {
+    crc = ~crc;
+    for (uint64_t i = 0; i < len; i++) {
+        crc ^= data[i];
+        for (uint32_t bit = 0; bit < 8; bit++) {
+            crc = (crc >> 1) ^ (0xedb88320u & (0u - (crc & 1u)));
+        }
+    }
+    return ~crc;
+}
+
+static uint32_t ds4_crc32(const uint8_t *data, uint64_t len) {
+    return ds4_crc32_update(0, data, len);
+}
+
+static bool ds4_u64_add_overflow(uint64_t a, uint64_t b, uint64_t *out) {
+    if (a > UINT64_MAX - b) return true;
+    *out = a + b;
+    return false;
+}
+
+static void ds4_bake_file_probe(ds4_model *m) {
+    const uint64_t mapped = m->mmap.size;
+    if (mapped < DS4_BAKE_FILE_FOOTER_SIZE) return;
+
+    const uint8_t *footer = m->map + (size_t)(mapped - DS4_BAKE_FILE_FOOTER_SIZE);
+    if (memcmp(footer, DS4_BAKE_FILE_MAGIC, 16) != 0) return;
+
+    const uint32_t version = ds4_read_le32(footer + 16);
+    const uint32_t n_layers = ds4_read_le32(footer + 20);
+    const uint32_t n_experts = ds4_read_le32(footer + 24);
+    const uint32_t mask_len = ds4_read_le32(footer + 28);
+    const uint64_t source_size = ds4_read_le64(footer + 32);
+    const uint64_t manifest_len = ds4_read_le64(footer + 40);
+    const uint32_t manifest_crc32 = ds4_read_le32(footer + 48);
+    const uint32_t mask_crc32 = ds4_read_le32(footer + 52);
+
+    if (version != DS4_BAKE_FILE_VERSION ||
+        n_layers != DS4_BAKE_EXPECTED_LAYERS ||
+        n_experts != DS4_N_EXPERT ||
+        mask_len != DS4_BAKE_EXPECTED_MASK_LEN) {
+        fprintf(stderr,
+                "ds4: DS4BAKE invalid footer version=%u layers=%u experts=%u mask_len=%u\n",
+                version,
+                n_layers,
+                n_experts,
+                mask_len);
+        ds4_die("DS4BAKE footer failed closed");
+    }
+
+    uint64_t trailer = 0;
+    uint64_t total = 0;
+    if (ds4_u64_add_overflow(manifest_len, mask_len, &trailer) ||
+        ds4_u64_add_overflow(trailer, DS4_BAKE_FILE_FOOTER_SIZE, &trailer) ||
+        ds4_u64_add_overflow(source_size, trailer, &total) ||
+        total != mapped ||
+        source_size > mapped ||
+        manifest_len > mapped ||
+        (uint64_t)mask_len > mapped) {
+        fprintf(stderr,
+                "ds4: DS4BAKE invalid trailer source=%" PRIu64 " manifest=%" PRIu64 " mask=%u mapped=%" PRIu64 "\n",
+                source_size,
+                manifest_len,
+                mask_len,
+                mapped);
+        ds4_die("DS4BAKE size validation failed closed");
+    }
+
+    const uint8_t *manifest = m->map + (size_t)source_size;
+    const uint8_t *mask = manifest + (size_t)manifest_len;
+    const uint32_t got_manifest_crc32 = ds4_crc32(manifest, manifest_len);
+    const uint32_t got_mask_crc32 = ds4_crc32(mask, mask_len);
+    if (got_manifest_crc32 != manifest_crc32 || got_mask_crc32 != mask_crc32) {
+        fprintf(stderr,
+                "ds4: DS4BAKE CRC mismatch manifest=%08x/%08x mask=%08x/%08x\n",
+                got_manifest_crc32,
+                manifest_crc32,
+                got_mask_crc32,
+                mask_crc32);
+        ds4_die("DS4BAKE checksum validation failed closed");
+    }
+
+    uint32_t retained_total = 0;
+    uint32_t active_layers = 0;
+    for (uint32_t il = 0; il < DS4_BAKE_EXPECTED_LAYERS; il++) {
+        uint32_t retained = 0;
+        for (uint32_t e = 0; e < DS4_N_EXPERT; e++) {
+            retained += (mask[il * DS4_BAKE_MASK_BYTES_PER_LAYER + e / 8u] >> (e % 8u)) & 1u;
+        }
+        if (retained < DS4_N_EXPERT_USED) {
+            fprintf(stderr,
+                    "ds4: DS4BAKE invalid layer=%u retained=%u required=%u\n",
+                    il,
+                    retained,
+                    (unsigned)DS4_N_EXPERT_USED);
+            ds4_die("DS4BAKE retained mask leaves too few experts");
+        }
+        if (retained < DS4_N_EXPERT) active_layers++;
+        retained_total += retained;
+    }
+
+    memcpy(m->bake_retained, mask, DS4_BAKE_EXPECTED_MASK_LEN);
+    m->bake_embedded = true;
+    m->bake_mapped_size = mapped;
+    m->bake_manifest_len = manifest_len;
+    m->bake_manifest_crc32 = manifest_crc32;
+    m->bake_mask_crc32 = mask_crc32;
+    m->size = source_size;
+
+    fprintf(stderr,
+            "ds4: DS4BAKE embedded mask loaded source=%" PRIu64 " mapped=%" PRIu64 " manifest=%" PRIu64 " active_layers=%u retained=%u/%u manifest_crc32=%08x mask_crc32=%08x\n",
+            source_size,
+            mapped,
+            manifest_len,
+            active_layers,
+            retained_total,
+            (unsigned)(DS4_BAKE_EXPECTED_LAYERS * DS4_N_EXPERT),
+            manifest_crc32,
+            mask_crc32);
+}
