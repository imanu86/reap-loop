         g_reap_mask_gpu_applied = failures == 0 && updates + creates == slot;
     }
     fprintf(stderr,
-            "ds4: REAP mask applied path=\"%s\" pruned=%u layers=%u bias_layers=%u ranges_updated=%u ranges_created=%u ranges_failed=%u\n",
-            g_reap_mask_path ? g_reap_mask_path : "",
+            "ds4: REAP mask applied source=\"%s\" pruned=%u layers=%u bias_layers=%u ranges_updated=%u ranges_created=%u ranges_failed=%u\n",
+            source,
             g_reap_mask_pruned_count,
             g_reap_mask_layer_count,
             g_reap_bias_n,
@@ -5420,7 +5572,73 @@ static void ds4_reap_mask_apply(const ds4_model *model, const ds4_weights *weigh
     }
 }
 
+static void ds4_reap_mask_check_env_conflict(void) {
+    if (!g_reap_mask_env_checked) {
+        g_reap_mask_env_checked = true;
+        const char *p = getenv("DS4_REAP_MASK_FILE");
+        if (p && p[0]) g_reap_mask_path = ds4_strdup(p);
+    }
+    if (g_reap_mask_embedded && g_reap_mask_path) {
+        fprintf(stderr,
+                "ds4: DS4BAKE embedded mask conflicts with DS4_REAP_MASK_FILE=\"%s\"\n",
+                g_reap_mask_path);
+        ds4_die("DS4BAKE refuses external REAP mask override");
+    }
+}
+
+static void ds4_reap_mask_install_embedded(const ds4_model *model, const ds4_weights *weights) {
+    if (!model || !model->bake_embedded) return;
+    g_reap_mask_embedded = true;
+    ds4_reap_mask_check_env_conflict();
+
+    memset(g_reap_mask_pruned, 0, sizeof(g_reap_mask_pruned));
+    memset(g_reap_mask_layer_active, 0, sizeof(g_reap_mask_layer_active));
+    memset(g_reap_bias_tensor, 0, sizeof(g_reap_bias_tensor));
+    g_reap_bias_n = 0;
+    g_reap_mask_pruned_count = 0;
+    g_reap_mask_layer_count = 0;
+    g_reap_mask_range_updates = 0;
+    g_reap_mask_range_creates = 0;
+    g_reap_mask_range_failures = 0;
+    g_reap_mask_gpu_applied = false;
+
+    for (uint32_t il = 0; il < DS4_N_LAYER; il++) {
+        uint32_t retained = 0;
+        uint32_t pruned = 0;
+        for (uint32_t e = 0; e < DS4_N_EXPERT; e++) {
+            const uint8_t byte = model->bake_retained[il][e / 8u];
+            const bool keep = ((byte >> (e % 8u)) & 1u) != 0;
+            if (keep) {
+                retained++;
+            } else {
+                g_reap_mask_pruned[il][e] = 1;
+                pruned++;
+            }
+        }
+        if (retained < DS4_N_EXPERT_USED) ds4_die("DS4BAKE retained mask leaves too few experts");
+        if (pruned != 0) {
+            g_reap_mask_layer_active[il] = 1;
+            g_reap_mask_layer_count++;
+            g_reap_mask_pruned_count += pruned;
+        }
+    }
+
+    g_reap_mask_loaded = true;
+    fprintf(stderr,
+            "ds4: DS4BAKE installed embedded retained mask pruned=%u active_layers=%u\n",
+            g_reap_mask_pruned_count,
+            g_reap_mask_layer_count);
+    ds4_reap_mask_apply(model, weights, false);
+}
