+/* patch 0046: soft-mask bias. DS4_REAP_MASK_SOFT_BIAS unset or 0.0 (default)
+ * reproduces the original hard -1e9 veto exactly. A nonzero finite value
+ * (e.g. -2.0) lets a pruned expert with very strong instantaneous demand
+ * still win the argmax/top-k in the SAME token, paying only a soft penalty
+ * instead of being categorically excluded. Independent of patch 0046's
+ * counterfactual admission fix; reads its env once and caches. Deliberately
+ * uses getenv/atof directly (not pace_env_d) because this helper's first
+ * caller runs before pace_env_* is defined further down the file. */
+static float ds4_reap_mask_bias_value(void) {
+    static int   cached = 0;
+    static float value = -1.0e9f;
+    if (!cached) {
+        const char *s = getenv("DS4_REAP_MASK_SOFT_BIAS");
+        double v = (s && *s) ? atof(s) : 0.0;
+        /* Post-review guard: atof("nan")/("inf")/garbage must never reach the
+         * router logits (NaN/inf bias would poison every downstream softmax),
+         * and a positive value would REWARD exclusion instead of penalizing
+         * it (a typo like "2.0" meant as "-2.0"). Reject both by falling back
+         * to the safe hard veto -- never silently do the opposite of what a
+         * soft-mask bias is for. */
+        if (!isfinite(v) || v >= 0.0) {
+            if (s && *s && v != 0.0)
+                fprintf(stderr,
+                        "ds4: REAP mask SOFT BIAS: rejecting invalid "
+                        "DS4_REAP_MASK_SOFT_BIAS=%s (must be finite and "
+                        "negative) -- falling back to HARD veto\n", s);
+            v = 0.0;
+        }
+        value = (v != 0.0) ? (float)v : -1.0e9f;
+        cached = 1;
+        fprintf(stderr,
+                "ds4: REAP mask bias = %s (%.4f)\n",
+                (value <= -1.0e9f) ? "HARD veto" : "SOFT finite",
+                (double)value);
+    }
+    return value;
+}
