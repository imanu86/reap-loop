+/* patch 0046 (post-review fix): an admitted expert's ring/sum FREEZE while it
+ * is resident -- note_probs only samples currently-excluded experts. If it is
+ * later expelled (mass10 victim) without clearing, its stale pre-expulsion
+ * sum can make it look like the top re-admission candidate on the very next
+ * growth event regardless of current demand: a ghost-churn source unrelated
+ * to any real signal. Call this at every live resident->excluded transition
+ * (never at admitted->resident, which needs no clear) so each exclusion
+ * stint starts cold. Cheap: O(1), only touched on actual mask transitions. */
+static inline void ds4_cf_admit_clear(uint32_t il, uint32_t e) {
+    if (il >= DS4_MAX_LAYER || e >= DS4_MAX_EXPERT) return;
+    memset(g_cf_admit_ring[il][e], 0, sizeof(g_cf_admit_ring[il][e]));
+    g_cf_admit_sum[il][e] = 0.0;
