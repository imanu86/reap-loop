+        if (ds4_gpu_tensor_read(g->cur_hc, 0, hc_read, hc_dim * sizeof(float)) != 0) {
+            double ss = 0.0;
+            for (uint64_t i = 0; i < hc_dim; i++) { const double v = hc_read[i]; ss += v * v; }
+            g_diag_hidden_l2 = sqrt(ss);
