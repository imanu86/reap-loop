 static void forward_token_raw_swa_cpu_decode_scratch(
@@ -10096,6 +10131,13 @@ static void forward_token_raw_swa_cpu_decode_scratch(
         next = tmp;
     }
 
+    if (ds4_diag_conf_enabled()) {
+        const uint64_t hc_dim = (uint64_t)DS4_N_HC * DS4_N_EMBD;
+        double ss = 0.0;
+        for (uint64_t i = 0; i < hc_dim; i++) { const double v = cur[i]; ss += v * v; }
+        g_diag_hidden_l2 = sqrt(ss);
+    }
+
     if (logits) {
         output_logits_one_decode_scratch(logits, model, weights, cur, scratch);
     }
