     }
@@ -26099,6 +26152,46 @@ static void trace_token_sidecar(const ds4_vocab *vocab, int token, int pos) {
     fputs("\"\n", tfh);
 }
 
+/* patch 0030: DS4_DIAG_CONF_LOG sidecar writer - see the declaration next to
+ * forward_token_raw_swa_cpu_decode_scratch for what expert_out_l2 actually
+ * is and is not. entropy/top1/top2/margin come straight from the logits
+ * array already in memory at the call site (one linear scan for top1/top2,
+ * one more accumulating a numerically-stable log-sum-exp for the Shannon
+ * entropy of softmax(logits) - no extra forward pass, no extra allocation
+ * beyond the lazy-open FILE static shared with the other 0012/0028
+ * sidecars). */
+static void trace_diag_conf(const float *logits, uint32_t n_vocab, int token, int pos) {
+    static FILE *dfh; static bool dchecked;
+    if (!dchecked) {
+        dchecked = true;
+        const char *p = getenv("DS4_DIAG_CONF_LOG");
+        if (p && *p) {
+            dfh = fopen(p, "w");
+            if (dfh) fprintf(dfh, "pos,token_id,entropy,top1_logit,top2_logit,margin,expert_out_l2\n");
+        }
+    }
+    if (!dfh || n_vocab == 0) return;
+    float top1 = logits[0];
+    float top2 = -1e30f;
+    for (uint32_t i = 1; i < n_vocab; i++) {
+        const float v = logits[i];
+        if (v > top1) { top2 = top1; top1 = v; }
+        else if (v > top2) { top2 = v; }
+    }
+    double sum = 0.0, weighted = 0.0;
+    for (uint32_t i = 0; i < n_vocab; i++) {
+        const double d = (double)logits[i] - (double)top1;
+        const double e = exp(d);
+        sum += e;
+        weighted += e * d;
+    }
+    const double entropy = sum > 0.0 ? (log(sum) - weighted / sum) : 0.0;
+    fprintf(dfh, "%d,%d,%.6f,%.9g,%.9g,%.9g,", pos, token, entropy,
+            (double)top1, (double)top2, (double)(top1 - top2));
+    if (g_diag_hidden_l2 >= 0.0) fprintf(dfh, "%.6f\n", g_diag_hidden_l2);
+    else fprintf(dfh, "nan\n");
+}
