+/* patch 0030: DS4_DIAG_CONF_LOG=/path.csv - per-token sampling confidence +
+ * post-block hidden L2 norm, one row per token generated. Unblocks two
+ * stalled threads: the pre-garbage-sensor hunt (needs entropy/margin of the
+ * sampling distribution BEFORE the model goes off the rails) and the
+ * MAN/MSAN score (needs ||f_{j,t}||2, confirmed absent from every trace on
+ * disk, runs/ds4/20260711_man_score/REPORT.md). Same lazy-open pattern as
+ * DS4_REAP_SENSOR_LOG (0012) / DS4_SPEX_TRACE_TOKENS (0028).
+ *
+ * expert_out_l2 is NOT a per-expert norm (that needs ||f_{j,t}|| read out of
+ * the MoE combine step itself, ds4_cuda.cu, out of scope for this patch): it
+ * is the L2 norm of the final post-block hidden state (scratch->cur /
+ * g->cur_hc, DS4_N_HC*DS4_N_EMBD floats) that feeds the LM head for this
+ * token - the aggregate effect of every attention+MoE layer combined, not an
+ * isolated per-expert signal. It is one step behind the trace call: it holds
+ * whatever the PREVIOUS forward pass left here, because that is the pass
+ * that produced the logits being sampled at the trace call site. Populated
+ * for CPU decode (forward_token_raw_swa_cpu_decode_scratch, below) and GPU
+ * non-streaming decode (metal_graph_encode_token_raw_swa). Left at the "not
+ * captured" sentinel (logged as "nan"): the very first sampled token (its
+ * logits come from prefill, not instrumented here) and every token under GPU
+ * SSD-streaming decode (metal_graph_eval_token_raw_swa_streaming, both its
+ * batch_static_decode and per-layer branches) - deliberately left alone
+ * rather than touch their per-layer command-buffer choreography without a
+ * CUDA toolchain to build+verify against (CPU-only authoring). */
+static double g_diag_hidden_l2 = -1.0;
+
+static bool ds4_diag_conf_enabled(void) {
+    static int cached = -1;
+    if (cached < 0) {
+        const char *v = getenv("DS4_DIAG_CONF_LOG");
+        cached = (v && v[0]) ? 1 : 0;
+    }
+    return cached == 1;
+}
+
