+static int cuda_transport_env_truthy(const char *name) {
+    const char *v = getenv(name);
+    return v && v[0] && strcmp(v, "0") != 0;
+}
+
+static int cuda_transport_diag_enabled(void) {
+    static int checked, enabled;
+    if (!checked) {
+        enabled = cuda_transport_env_truthy("DS4_CUDA_TRANSPORT_DIAG");
+        checked = 1;
+    }
+    return enabled;
+}
+
+static int cuda_transport_debug_enabled(void) {
+    static int checked, enabled;
+    if (!checked) {
+        enabled = cuda_transport_env_truthy("DS4_CUDA_TRANSPORT_DEBUG");
+        checked = 1;
+    }
+    return enabled;
+}
+
+static int cuda_transport_fault_once(
+        const char *env_name,
+        int *state,
+        const char *label) {
+    if (*state == 0) {
+        const int armed = cuda_transport_env_truthy(env_name) ? 1 : -1;
+        (void)__sync_bool_compare_and_swap(state, 0, armed);
+    }
+    if (__sync_bool_compare_and_swap(state, 1, 2)) {
+        fprintf(stderr, "ds4: CUDA transport fault injected: %s\n", label);
+        return 1;
+    }
+    return 0;
+}
+
+static uint64_t cuda_transport_failure_count(void) {
