+static void cuda_transport_latch_sync_staging(const char *why) {
+    if (!g_stream_selected_stage_sync_mode) {
+        g_stream_selected_stage_sync_mode = 1;
+        fprintf(stderr,
+                "ds4: CUDA transport safe synchronous staging mode latched (%s)\n",
+                why ? why : "event failure");
+    }
+}
+
+static void cuda_transport_clear_deferred_state(void) {
+    g_stream_selected_upload_done_recorded = 0;
+    g_stream_selected_stage_defer_inflight = 0;
+    for (size_t i = 0; i < DS4_STREAM_SELECTED_STAGE_MAX; i++) {
+        if (g_stream_selected_stage_slot_inflight[i]) {
+            g_stream_selected_stage_completed_generation[i] =
+                g_stream_selected_stage_generation[i];
+            g_stream_selected_stage_slot_inflight[i] = 0;
+        }
+    }
+}
+
+static void cuda_transport_stage_mark_enqueued(uint64_t slot) {
+    if (slot >= DS4_STREAM_SELECTED_STAGE_MAX) return;
+    g_stream_selected_stage_generation[slot]++;
+    g_stream_selected_stage_slot_inflight[slot] = 1;
+}
+
+static void cuda_transport_stage_mark_complete(uint64_t slot) {
+    if (slot >= DS4_STREAM_SELECTED_STAGE_MAX) return;
+    g_stream_selected_stage_completed_generation[slot] =
+        g_stream_selected_stage_generation[slot];
+    g_stream_selected_stage_slot_inflight[slot] = 0;
+}
+
+static int cuda_transport_drain_upload_stream(
+        const char *what,
+        int latch_sync_mode,
+        int log_success) {
+    if (latch_sync_mode) cuda_transport_latch_sync_staging(what);
+    g_transport_safety_diag.fallback_syncs++;
+    /* A NULL CUDA stream handle is the default stream, not "no stream". */
+    cudaError_t err = cudaStreamSynchronize(g_stream_selected_upload_stream);
+    cuda_transport_clear_deferred_state();
+    if (err != cudaSuccess) {
+        g_transport_safety_diag.fallback_sync_failures++;
+        fprintf(stderr,
+                "ds4: CUDA transport fallback sync failed for %s: %s\n",
+                what ? what : "selected upload",
+                cudaGetErrorString(err));
+        (void)cudaGetLastError();
+        return 0;
+    }
+    if (log_success) {
+        fprintf(stderr,
+                "ds4: CUDA transport fallback sync succeeded for %s\n",
+                what ? what : "selected upload");
+    }
+    return 1;
+}
