+/* Return 1 when completion remains deferred behind an event, 2 when event
+ * bookkeeping failed but a full upload-stream drain made the copy synchronous,
+ * and 0 only when that safety drain also failed. */
+static int cuda_stream_selected_upload_record_or_drain(const char *what) {
+    if (!cuda_stream_selected_upload_done_event_ensure()) {
+        return cuda_transport_drain_upload_stream(
+                   what ? what : "upload event create failure", 1, 1) ? 2 : 0;
+    }
+    const int injected = cuda_transport_fault_once(
+        "DS4_CUDA_FAULT_UPLOAD_EVENT_RECORD",
+        &g_fault_upload_event_record,
+        "upload_event_record");
+    cudaError_t err = injected ? cudaErrorUnknown :
+        cudaEventRecord(g_stream_selected_upload_done_event,
+                        g_stream_selected_upload_stream);
+    if (err != cudaSuccess) {
+        g_transport_safety_diag.upload_event_record_failures++;
+        fprintf(stderr,
+                "ds4: CUDA streaming selected upload event record failed for %s: %s\n",
+                what ? what : "selected upload",
+                injected ? "injected fault" : cudaGetErrorString(err));
+        (void)cudaGetLastError();
+        return cuda_transport_drain_upload_stream(
+                   what ? what : "upload event record failure", 1, 1) ? 2 : 0;
+    }
+    g_stream_selected_upload_done_recorded = 1;
+    return 1;
+}
