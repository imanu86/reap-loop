+            "fallback_syncs=%llu fallback_sync_failures=%llu "
+            "staged_h2d_failures=%llu stale_slot_reads=%llu sync_stage_mode=%d\n",
+            phase ? phase : "exit",
+            (unsigned long long)g_transport_safety_diag.stage_chunks,
+            (unsigned long long)g_transport_safety_diag.cursor_advances,
+            (unsigned long long)g_transport_safety_diag.slot_reuses,
+            (unsigned long long)g_transport_safety_diag.war_waits,
+            (unsigned long long)g_transport_safety_diag.war_wait_failures,
+            (unsigned long long)g_transport_safety_diag.stage_event_create_failures,
+            (unsigned long long)g_transport_safety_diag.stage_event_record_failures,
