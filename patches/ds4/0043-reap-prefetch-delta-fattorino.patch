+                promo[promo_n].expert = (uint32_t)cand;
+                promo_n++;
+            }
             if (g_pace.lm_log) {
                 fprintf(g_pace.lm_log,
                     "{\"ev\":\"swap\",\"tok\":%u,\"layer\":%u,\"in\":%d,"
@@ -13628,6 +13811,11 @@
