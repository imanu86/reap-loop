+/* ---- S1-slope trigger (patch 0020) ---- */
+static void ds4_pace_emit_s1(const char *ev) {
+    if (g_pace.debug) {
+        fprintf(stderr,
+                "ds4: PACE %-12s tok=%u keep=%d s1=%.4f slope=%.6f over=%u\n",
+                ev, g_pace.tok, g_pace.cur_keep, g_pace.ema_s1,
+                g_pace.s1_slope, g_pace.s1_over);
+    }
+    if (g_pace.evlog) {
+        fprintf(g_pace.evlog,
+                "{\"ev\":\"%s\",\"tok\":%u,\"keep\":%d,\"s1\":%.5f,"
+                "\"slope\":%.7f,\"over\":%u,\"action\":\"%s\"}\n",
+                ev, g_pace.tok, g_pace.cur_keep, g_pace.ema_s1,
+                g_pace.s1_slope, g_pace.s1_over,
+                g_pace.s1_action == DS4_PACE_S1_ACT_WIDEN ? "widen" : "rotate");
+        fflush(g_pace.evlog);
+    }
+}
+
+/* Fold the last token's S1 sample into the EWMA, update the slope over the
+ * s1_slope_win window and the consecutive-over counter. Called once per
+ * decode token from ds4_pace_tick (the layer hooks of token N accumulate
+ * s1_tok_* before the tick of token N+1 folds them). */
+static void ds4_pace_s1_update(void) {
+    if (!g_pace.s1_on) return;
+    if (g_pace.s1_tok_total > 0.0) {
+        const double s1 = g_pace.s1_tok_pruned / g_pace.s1_tok_total;
+        g_pace.ema_s1 = (1.0 - g_pace.alpha_s1) * g_pace.ema_s1
+                      + g_pace.alpha_s1 * s1;
+        const uint32_t w = g_pace.s1_slope_win;
+        if (g_pace.s1_ring_len < w) {
+            g_pace.s1_ring[(g_pace.s1_ring_head + g_pace.s1_ring_len) % w] =
+                g_pace.ema_s1;
+            g_pace.s1_ring_len++;
+        } else {
+            g_pace.s1_ring[g_pace.s1_ring_head] = g_pace.ema_s1;
+            g_pace.s1_ring_head = (g_pace.s1_ring_head + 1) % w;
+        }
+        if (g_pace.s1_ring_len >= w && w > 1) {
+            /* the oldest sample sits at ring_head once the ring is full */
+            const double oldest = g_pace.s1_ring[g_pace.s1_ring_head];
+            g_pace.s1_slope = (g_pace.ema_s1 - oldest) / (double)(w - 1);
+        } else {
+            g_pace.s1_slope = 0.0;
+        }
+        /* consecutive-over counter; refractory of one window after a fire */
+        if (g_pace.s1_trigger &&
+            g_pace.s1_ring_len >= w &&
+            g_pace.tok - g_pace.s1_last_fire_tok >= w &&
+            g_pace.s1_slope >= g_pace.s1_slope_thr) {
+            g_pace.s1_over++;
+        } else {
+            g_pace.s1_over = 0;
+        }
+    }
+    g_pace.s1_tok_pruned = 0.0;
+    g_pace.s1_tok_total  = 0.0;
+}
+
+static inline int ds4_pace_s1_trigger_due(void) {
+    return g_pace.s1_on && g_pace.s1_trigger &&
+           g_pace.cur_keep > 0 &&
+           g_pace.s1_over >= g_pace.s1_stable;
+}
