         if (!clock_due && !sensor_due &&
             g_pace.prebreath_on &&
             g_pace.sensor_armed &&
@@ -16198,13 +16387,16 @@ static void metal_graph_spex_note_selected(
         const int32_t *selected_ids,
         uint32_t       n_selected) {
     metal_graph_spex_trace_selected(g, il, selected_ids, n_selected);
