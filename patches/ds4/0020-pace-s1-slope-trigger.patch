+/* ---- S1 pruned-mass monitor (patch 0020) ---- *
+ * In-memory version of the 0012 S1 sensor: router probability mass falling
+ * on PRUNED experts (the router still scores all experts under the 0011
+ * bias mask). The absolute level is measured dead as a signal; the EWMA
+ * SLOPE is the only measured pre-collapse riser (CLAIM-011). Fed from the
+ * same raw-router readback as rotation (metal_graph_spex_note_selected). */
+static inline int ds4_pace_s1_wants_router(void) {
+    if (!ds4_pace_active()) return 0;
+    return g_pace.s1_on && !g_pace.in_prefill &&
+           g_pace.cur_keep > 0 && g_reap_mask_on;
+}
+
+static void ds4_pace_s1_note_probs(uint32_t il, const float *probs) {
+    if (!probs || il >= DS4_MAX_LAYER || !ds4_pace_s1_wants_router()) return;
+    double tot = 0.0, pr = 0.0;
+    for (uint32_t e = 0; e < DS4_N_EXPERT && e < DS4_MAX_EXPERT; e++) {
+        const double v = (double)probs[e];
+        tot += v;
+        if (g_reap_mask_pruned[il][e]) pr += v;
+    }
+    g_pace.s1_tok_pruned += pr;
+    g_pace.s1_tok_total  += tot;
+}
+
 /* ---- learn keep-set from an accumulator into g_reap_mask_pruned ---- *
  * top-keep experts per layer by accumulated mass are KEPT; rest pruned. */
 static void ds4_pace_learn_mask(const double *acc, int keep) {
@@ -13206,6 +13283,15 @@ static void ds4_pace_reset_for_prefill(const ds4_model *model,
     g_pace.sel_inkeep = 0;
     g_pace.ema_hit = 1.0;
     g_pace.breaths = 0;
+    g_pace.s1_tok_pruned = 0.0;
+    g_pace.s1_tok_total = 0.0;
+    g_pace.ema_s1 = 0.0;
+    g_pace.s1_ring_len = 0;
+    g_pace.s1_ring_head = 0;
+    g_pace.s1_slope = 0.0;
+    g_pace.s1_over = 0;
+    g_pace.s1_last_fire_tok = 0;
+    g_pace.s1_events = 0;
     ds4_pace_emit(why && *why ? why : "prefill_reset", 0.0, 1.0);
 }
 
