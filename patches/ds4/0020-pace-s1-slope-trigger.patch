@@ -13314,6 +13465,27 @@ static int ds4_pace_rotate_maybe(const ds4_model *model, const ds4_weights *weig
     return 1;
 }
 
+/* patch 0020: forced K-constant rotate, no cadence gate - used by the
+ * S1-slope trigger (an S1 fire IS the clock). Same body as
+ * ds4_pace_rotate_maybe minus rotate_on and the rotate_every gate. The why
+ * string stays "rotate" so the 0018 WRAP-on-rotate policy (and a delta
+ * page-in policy layered on it) apply unchanged. */
+static int ds4_pace_rotate_force(const ds4_model *model, const ds4_weights *weights) {
+    if (!g_pace.rmass || g_pace.phase != PACE_HOLD ||
+        g_pace.cur_keep <= 0 || g_pace.rmass_rows == 0) {
+        return 0;
+    }
+    const uint32_t stable_before = g_pace.stable_since;
+    ds4_pace_apply_keep_acc(model, weights, g_pace.rmass, g_pace.cur_keep, "rotate");
+    if (g_pace.rotate_preserve_stable) {
+        g_pace.stable_since = stable_before;
+    }
+    g_pace.last_rotate_tok = g_pace.tok;
+    g_pace.rotate_events++;
+    ds4_pace_emit("rotate(s1)", g_pace.ema_ngram, g_pace.ema_hit);
+    return 1;
+}
