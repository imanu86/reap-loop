+    ds4_pace_s1_update();   /* 0020: S1 EWMA + slope from last token's layers */
 
     switch (g_pace.phase) {
     case PACE_WARMUP:
@@ -13359,6 +13532,22 @@ static void ds4_pace_tick(const ds4_model *model, const ds4_weights *weights,
         }
         int sensor_due = g_pace.sensor_armed && g_pace.ema_ngram >= g_pace.drift;
 
+        /* patch 0020: S1-slope predictive trigger (CLAIM-011). Fires when
