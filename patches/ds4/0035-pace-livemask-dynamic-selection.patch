+/* ======================================================================== *
+ * PATCH 0035 - PACE LIVEMASK: a live, self-built dynamic K-wide SELECTION
+ * mask. Master gate DS4_PACE_LIVEMASK (default 0), INDEPENDENT of DS4_PACE
+ * and DS4_REAP_MASK_FILE. Bootstraps at true K0 on the live prompt, seeds a
+ * top-K mask from observed unbiased routing demand, then keeps a hard sliding
+ * window (last W generated tokens) as the promote/prune RATING and does at
+ * most a couple Anchor-Law-gated one-in/one-out swaps per layer per scan.
+ * Reuses the 0011 actuator (g_reap_mask_pruned + ds4_reap_mask_apply). ON
+ * intentionally breaks bit-exactness (restricting selection is the point);
+ * OFF is a pure no-op (byte-identical to stock).
+ * ======================================================================== */
+#ifndef DS4_LM_WIN_MAX
+#define DS4_LM_WIN_MAX 32
+#endif
+#ifndef DS4_LM_OBS_MAX
+#define DS4_LM_OBS_MAX 16
+#endif
+
+static inline int ds4_pace_livemask_active(void) {
+    if (g_pace.enabled == 0) ds4_pace_init();
+    return g_pace.lm_on != 0;
+}
+
+/* True during BOTH bootstrap and post-seed decode; false in prefill. OR-ed into
+ * the existing router_probs readback guard. */
+static inline int ds4_pace_livemask_wants_router(void) {
+    return ds4_pace_livemask_active() && !g_pace.lm_in_prefill;
+}
+
+/* exp_probs_b exists only on the non-hash layers (3..42); hash layers 0-2 have
+ * no router bias and must never be masked. */
+static inline int ds4_pace_livemask_layer_ok(const ds4_weights *weights,
+                                             uint32_t il) {
+    return weights && il < DS4_N_LAYER && il < DS4_MAX_LAYER &&
+           weights->layer[il].ffn_exp_probs_b != NULL;
+}
+
+/* Partial-select the unbiased top-obs of probs[] by value (obs << N_EXPERT).
+ * out_share[j] = probs[id] / sum(all probs). Returns the number selected. */
+static int ds4_pace_livemask_topk(const float *probs, uint16_t *out_id,
+                                  float *out_share, int obs) {
+    if (!probs || obs <= 0) return 0;
+    if (obs > DS4_LM_OBS_MAX) obs = DS4_LM_OBS_MAX;
+    uint32_t ne = DS4_N_EXPERT;
+    if (ne > DS4_MAX_EXPERT) ne = DS4_MAX_EXPERT;
+    double tot = 0.0;
+    for (uint32_t e = 0; e < ne; e++) tot += (double)probs[e];
+    if (tot <= 0.0) tot = 1.0;
+    int n = 0;
+    for (int k = 0; k < obs && (uint32_t)k < ne; k++) {
+        int best = -1;
+        float bestv = -3.4e38f;
+        for (uint32_t e = 0; e < ne; e++) {
+            int seen = 0;
+            for (int p = 0; p < n; p++) {
+                if (out_id[p] == (uint16_t)e) { seen = 1; break; }
+            }
+            if (seen) continue;
+            if (probs[e] > bestv) { bestv = probs[e]; best = (int)e; }
+        }
+        if (best < 0) break;
+        out_id[n] = (uint16_t)best;
+        out_share[n] = (float)((double)probs[best] / tot);
+        n++;
+    }
+    return n;
+}
+
+/* Forward-pass hook: record this token/layer unbiased top-obs into the scratch.
+ * Uses UNBIASED probs (pre exp_probs_b) so a BLOCKED expert still registers true
+ * demand - the invariant the seed tripwire guards. */
+static void ds4_pace_livemask_note_probs(uint32_t il, const float *probs) {
+    if (!g_pace.lm_on || g_pace.lm_in_prefill) return;
+    if (il >= DS4_N_LAYER || il >= DS4_MAX_LAYER || !probs) return;
+    uint16_t *id = &g_pace.lm_cur_id[(size_t)il * DS4_LM_OBS_MAX];
+    float    *sh = &g_pace.lm_cur_share[(size_t)il * DS4_LM_OBS_MAX];
+    g_pace.lm_cur_n[il] = ds4_pace_livemask_topk(probs, id, sh, g_pace.lm_observe_top);
+}
+
+/* Roll the ring exactly one slot: evict the token leaving the window (subtract
+ * its stored floats), then overwrite the slot with the just-finished token
+ * (add). Subtract-then-add of the SAME stored floats keeps the window sum
+ * exact. This hard window (not EWMA) is the phase-adaptivity engine. */
+static void ds4_pace_livemask_commit(void) {
+    if (!g_pace.lm_on) return;
+    int W = g_pace.lm_window;
+    if (W <= 0) return;
+    int s = g_pace.lm_ring_pos;
+    for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER; il++) {
+        size_t rbase = ((size_t)s * DS4_MAX_LAYER + il) * DS4_LM_OBS_MAX;
+        uint16_t *rid = &g_pace.lm_ring_id[rbase];
+        float    *rsh = &g_pace.lm_ring_share[rbase];
+        size_t nslot = (size_t)s * DS4_MAX_LAYER + il;
+        uint16_t *wc = &g_pace.lm_wcount[(size_t)il * DS4_MAX_EXPERT];
+        double   *ws = &g_pace.lm_wshare[(size_t)il * DS4_MAX_EXPERT];
+        int oldn = g_pace.lm_ring_n[nslot];
+        for (int j = 0; j < oldn; j++) {
+            uint16_t e = rid[j];
+            if (e < DS4_MAX_EXPERT) {
+                if (wc[e] > 0) wc[e]--;
+                ws[e] -= (double)rsh[j];
+            }
+        }
+        int n = g_pace.lm_cur_n[il];
+        if (n > DS4_LM_OBS_MAX) n = DS4_LM_OBS_MAX;
+        uint16_t *cid = &g_pace.lm_cur_id[(size_t)il * DS4_LM_OBS_MAX];
+        float    *csh = &g_pace.lm_cur_share[(size_t)il * DS4_LM_OBS_MAX];
+        for (int j = 0; j < n; j++) {
+            uint16_t e = cid[j];
+            float sv = csh[j];
+            rid[j] = e;
+            rsh[j] = sv;
+            if (e < DS4_MAX_EXPERT) {
+                wc[e]++;
+                ws[e] += (double)sv;
+            }
+        }
+        g_pace.lm_ring_n[nslot] = n;
+        g_pace.lm_cur_n[il] = 0;
+    }
+    g_pace.lm_ring_pos = (s + 1) % W;
+    if (g_pace.lm_ring_fill < W) g_pace.lm_ring_fill++;
+}
+
+/* At token ~bootstrap: build the K-wide mask = top-K experts/layer by windowed
+ * demand (count primary, share tiebreak), push it through the 0011 actuator. */
+static void ds4_pace_livemask_seed(const ds4_model *model,
+                                   const ds4_weights *weights) {
+    if (!g_pace.lm_on) return;
+    int K = g_pace.lm_k;
+    uint32_t ne = DS4_N_EXPERT;
+    if (ne > DS4_MAX_EXPERT) ne = DS4_MAX_EXPERT;
+    uint8_t keep[DS4_MAX_EXPERT];
+    for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER; il++) {
+        if (!ds4_pace_livemask_layer_ok(weights, il)) continue;
+        memset(keep, 0, ne);
+        const uint16_t *wc = &g_pace.lm_wcount[(size_t)il * DS4_MAX_EXPERT];
+        const double   *ws = &g_pace.lm_wshare[(size_t)il * DS4_MAX_EXPERT];
+        for (int k = 0; k < K; k++) {
+            int best = -1;
+            long bestc = -1;
+            double bests = -1.0;
+            for (uint32_t e = 0; e < ne; e++) {
+                if (keep[e]) continue;
+                long c = (long)wc[e];
+                if (c > bestc || (c == bestc && ws[e] > bests)) {
+                    bestc = c; bests = ws[e]; best = (int)e;
+                }
+            }
+            if (best < 0) break;
+            keep[best] = 1;
+        }
+        for (uint32_t e = 0; e < ne; e++)
+            g_reap_mask_pruned[il][e] = keep[e] ? 0 : 1;
+    }
+    /* Router-probs-unbiased tripwire (one-shot): at least one PRUNED expert must
+     * retain nonzero windowed share, else the readback distribution is biased
+     * (mask folded into probs) and live re-admission would silently freeze. */
+    if (!g_pace.lm_assert_done) {
+        g_pace.lm_assert_done = 1;
+        int ok = 0;
+        for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER && !ok; il++) {
+            if (!ds4_pace_livemask_layer_ok(weights, il)) continue;
+            const double *ws = &g_pace.lm_wshare[(size_t)il * DS4_MAX_EXPERT];
+            for (uint32_t e = 0; e < ne; e++) {
+                if (g_reap_mask_pruned[il][e] && ws[e] > 0.0) { ok = 1; break; }
+            }
+        }
+        if (!ok) {
+            fprintf(stderr,
+                "ds4: PACE LIVEMASK WARNING: no pruned expert retains nonzero windowed "
+                "share at seed - router_probs readback may be BIASED (mask folded into "
+                "probs); live re-admission would freeze. (reported once)\n");
+        }
+    }
+    /* Mutual-exclusion one-shot: LIVEMASK owns g_reap_mask_pruned. */
+    if (!g_pace.lm_warned_mutex) {
+        g_pace.lm_warned_mutex = 1;
+        const char *mf = getenv("DS4_REAP_MASK_FILE");
+        int pace_mask = (ds4_pace_active() && (g_pace.keep > 0 || g_pace.rotate_on));
+        if ((mf && *mf) || pace_mask) {
+            fprintf(stderr,
+                "ds4: PACE LIVEMASK WARNING: another g_reap_mask_pruned writer is active "
+                "(DS4_PACE keep/rotate, DS4_REAP_MASK_FILE, 0026 admit or 0015 rotate) - "
+                "LIVEMASK owns the mask; running two corrupts the anchor. (reported once)\n");
+        }
+    }
+    ds4_reap_mask_apply(model, weights);          /* 0011 actuator */
+    g_pace.lm_seeded = 1;
+    if (g_pace.lm_log) {
+        fprintf(g_pace.lm_log,
+                "{\"ev\":\"seed\",\"tok\":%u,\"K\":%d,\"window\":%d}\n",
+                g_pace.lm_tok, g_pace.lm_k, g_pace.lm_window);
+        fflush(g_pace.lm_log);
+    }
+    fprintf(stderr, "ds4: PACE LIVEMASK seeded at tok=%u K=%d window=%d\n",
+            g_pace.lm_tok, g_pace.lm_k, g_pace.lm_window);
+}
+
+/* Continuous loop: per eligible layer, cooldown-gated, up to max_swaps one-in/
+ * one-out swaps. Triple-gate: sustained knock (count>=X), candidate hotter by
+ * hyst, per-layer cooldown. K stays constant; window roll-off is the decay. */
+static void ds4_pace_livemask_scan(const ds4_model *model,
+                                   const ds4_weights *weights) {
+    if (!g_pace.lm_on || !g_pace.lm_seeded) return;
+    uint32_t ne = DS4_N_EXPERT;
+    if (ne > DS4_MAX_EXPERT) ne = DS4_MAX_EXPERT;
+    int dirty = 0;
+    for (uint32_t il = 0; il < DS4_N_LAYER && il < DS4_MAX_LAYER; il++) {
+        if (!ds4_pace_livemask_layer_ok(weights, il)) continue;
+        if ((g_pace.lm_tok - g_pace.lm_last_swap_tok[il]) <
+            (uint32_t)g_pace.lm_cooldown) continue;
+        const uint16_t *wc = &g_pace.lm_wcount[(size_t)il * DS4_MAX_EXPERT];
+        const double   *ws = &g_pace.lm_wshare[(size_t)il * DS4_MAX_EXPERT];
+        for (int sw = 0; sw < g_pace.lm_max_swaps; sw++) {
+            int cand = -1;
+            long candc = -1;
+            for (uint32_t e = 0; e < ne; e++) {
+                if (!g_reap_mask_pruned[il][e]) continue;
+                if ((long)wc[e] > candc) { candc = (long)wc[e]; cand = (int)e; }
+            }
+            int vic = -1;
+            double vmin = 1e300;
+            for (uint32_t e = 0; e < ne; e++) {
+                if (g_reap_mask_pruned[il][e]) continue;
+                if (ws[e] < vmin) { vmin = ws[e]; vic = (int)e; }
+            }
+            if (cand < 0 || vic < 0) break;
+            if ((long)wc[cand] < (long)g_pace.lm_x) break;         /* sustained knock */
+            if (ws[cand] < ws[vic] + g_pace.lm_hyst) break;        /* hotter by margin */
+            g_reap_mask_pruned[il][vic]  = 1;
+            g_reap_mask_pruned[il][cand] = 0;
+            g_pace.lm_last_swap_tok[il]  = g_pace.lm_tok;
+            dirty = 1;
+            if (g_pace.lm_log) {
+                fprintf(g_pace.lm_log,
+                    "{\"ev\":\"swap\",\"tok\":%u,\"layer\":%u,\"in\":%d,"
+                    "\"out\":%d,\"cand_count\":%ld,\"cand_share\":%.6g,"
+                    "\"vic_share\":%.6g}\n",
+                    g_pace.lm_tok, il, cand, vic, (long)wc[cand], ws[cand], ws[vic]);
+                fflush(g_pace.lm_log);
+            }
+        }
+    }
+    /* One device apply per scan if anything moved (0011 actuator). The 0021
+     * delta-prefetch that would page in the entered expert is not present in
+     * this applied chain; residency instead follows the selection stream
+     * emergently through 0033 (first-request cold miss, then re-pin). */
+    if (dirty) ds4_reap_mask_apply(model, weights);
+}
+
+/* Per-decode-token driver. EXACT ORDERING kills the off-by-one:
+ * (1) commit the PRIOR token, (2) bootstrap-gate / seed, (3) else scan,
+ * (4) advance tok. note_probs for this token then runs during its forward pass,
+ * feeding the NEXT commit. */
+static void ds4_pace_livemask_tick(const ds4_model *model,
+                                   const ds4_weights *weights) {
+    if (!g_pace.lm_on) return;
+    g_pace.lm_in_prefill = 0;                       /* decode has begun */
+    ds4_pace_livemask_commit();                     /* (1) */
+    if (!g_pace.lm_seeded) {                         /* (2) */
+        if (g_pace.lm_tok < (uint32_t)g_pace.lm_bootstrap) {
+            g_pace.lm_tok++;
+            return;
+        }
+        ds4_pace_livemask_seed(model, weights);
+        g_pace.lm_tok++;
+        return;
+    }
+    ds4_pace_livemask_scan(model, weights);         /* (3) */
+    g_pace.lm_tok++;                                /* (4) */
+}
+
+/* Prefill boundary: zero all live state and unmask on device so the next prompt
+ * re-bootstraps at true K0 (mask-matched-at-birth). */
